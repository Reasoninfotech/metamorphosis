document.addEventListener("DOMContentLoaded", function () {
  document.querySelectorAll(".hot-dot-wrp").forEach(function (hotDot) {
    hotDot.addEventListener("click", function (event) {
        event.stopPropagation(); // Prevent body click event from triggering

        const siblingTooltip = this.parentElement.querySelector(".tooltip-pro-frist");
        const isActive = this.classList.contains("active");

        // Remove active class and hide tooltips for all
        document.querySelectorAll(".hot-dot-wrp").forEach(dot => dot.classList.remove("active"));
        document.querySelectorAll(".tooltip-pro-frist").forEach(tooltip => tooltip.style.display = "none");

        // Toggle only for the clicked one
        if (!isActive) {
            this.classList.add("active");
            siblingTooltip.style.display = "flex";
        }
    });
});

// Click anywhere on the body to remove active state and hide tooltips
document.body.addEventListener("click", function () {
    document.querySelectorAll(".hot-dot-wrp").forEach(dot => dot.classList.remove("active"));
    document.querySelectorAll(".tooltip-pro-frist").forEach(tooltip => tooltip.style.display = "none");
});
});

  
</script>


