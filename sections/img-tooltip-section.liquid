{% style %}
 @keyframes zoom-in-zoom-out {
  0% {
    transform: scale(1, 1);
  }
  50% {
    transform: scale(1.5, 1.5);
  }
  100% {
    transform: scale(1, 1);
  }
}

.img-with-tooltip .main_title{margin-bottom: 48px;}  

.img-with-tooltip .img_with_text_block figure{overflow: hidden;position: relative;}
.img-with-tooltip .img_with_text_block figure img{width: 100%;vertical-align: middle;object-fit: cover;}
.img-with-tooltip .img_with_text_block figure .mobile-img{display:none;}

.img-with-tooltip .img_with_text_block .tooltip .hot-dot-wrp{position: absolute;left: 0;top: 0;padding: 5px;cursor: pointer;width: fit-content;background: transparent;color: #000;border-radius: 50px;display: block;box-shadow: 0 0 10px #fff;animation: zoom-in-zoom-out 5s ease-out infinite;}
.img-with-tooltip .img_with_text_block .tooltip .hot-dot-wrp .hotspot__dot{display: block;width: 18px;height: 18px;border-radius: 50px;border:1px solid #fff;}
.img-with-tooltip .img_with_text_block .tooltip .hot-dot-wrp.active .hotspot__dot{background: #fff;border: unset;}

.img-with-tooltip .img_with_text_block .hot-colse{position: absolute;background: #fff;padding: 5px;cursor: pointer;width: fit-content;background: #fff;color: #000;display:flex;right: 0;top: 0;}

.img-with-tooltip .tooltip-pro-frist{position: absolute;left: 0;top: 0;display: none;background: #fff;padding: 24px;transform: translateX(13%);width: 80%;z-index: 1;flex-direction: column;max-width: 250px;gap:16px;}

  .img-with-tooltip .tooltip-pro-frist .product-img img {
    max-height: 200px;
    object-fit: contain;
}
  
.img-with-tooltip .pro_title{display: flex;flex-direction: column;text-align: center;}
.img-with-tooltip .pro_title a{text-decoration: none;font-weight: 700;line-height: normal;font-size: 20px;max-width: 200px;margin: 0 auto;}
.img-with-tooltip .pro_title .price-money{color: #CA003D;font-weight: 700;font-size: 24px;line-height: normal;}

.img-with-tooltip .product-form__buttons{text-align:center;}
.img-with-tooltip .cus_add_to_cart .common_btn{min-width: 80%;background: transparent;}
  
.img-with-tooltip figcaption{max-width: 970px;margin: 48px auto 0;text-align: center;}
.img-with-tooltip figcaption p{margin:0;font-size: 20px;line-height: normal;color:#000;}

.img-with-tooltip .img-tooltip_btn_wrp{margin-top: 48px;text-align: center;}


@media screen and (max-width:1199px){
  .img-with-tooltip .pro_title a{font-size:18px;}
}  

@media screen and (max-width:991px){
  .img-with-tooltip .img_with_text_block figure .des_img{display:none;}
  .img-with-tooltip .img_with_text_block figure .mobile-img{display:block;}

  .img-with-tooltip .tooltip.ttip_1 .hot-dot-wrp{top: {{ section.settings.mobile-top-postion }}%!important;left: {{ section.settings.mobile-left-postion }}%!important;}
  .img-with-tooltip .tooltip.ttip_2 .hot-dot-wrp{top: {{ section.settings.mobile-top-postion2 }}%!important;left: {{ section.settings.mobile-left-postion2 }}%!important;}
  .img-with-tooltip .tooltip.ttip_3 .hot-dot-wrp{top: {{ section.settings.mobile-top-postion3 }}%!important;left: {{ section.settings.mobile-left-postion3 }}%!important;}

  .img-with-tooltip .tooltip.ttip_1 .tooltip-pro-frist,
  .img-with-tooltip .tooltip.ttip_2 .tooltip-pro-frist,
  .img-with-tooltip .tooltip.ttip_3 .tooltip-pro-frist{top:50%!important;left:50%!important;transform: translate(-50%, -50%);}

}  

@media screen and (max-width:768px){
  .img-with-tooltip .pro_title a{font-size:16px;max-width: 100%;}
  .img-with-tooltip .cus_add_to_cart .common_btn{min-width:100%;padding:10px;}
  .img-with-tooltip .pro_title .price-money{fomnt-size:20px;}
}

@media screen and (max-width:575px){
  .img-with-tooltip .main_title{margin-bottom: 32px;}
  .img-with-tooltip .tooltip-pro-frist{gap:10px;}
  .img-with-tooltip figcaption{margin: 32px auto 0;}
  .img-with-tooltip .img-tooltip_btn_wrp{margin-top: 32px;}
  .img-with-tooltip .img-tooltip_btn_wrp .common_btn{min-width: 280px;}
 .img-with-tooltip .tooltip-pro-frist {
    padding: 24px;
} 
}

@media screen and (max-width:400px){
  .img-with-tooltip .tooltip-pro-frist {
    padding: 10px;
} 
}  
  
