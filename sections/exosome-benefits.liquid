{% schema %}
{
  "name": "Exosome Serum Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image"
    },
    {
      "type": "image_picker",
      "id": "bottom_image",
      "label": "Bottom Static Image"
    },
    {
        "type": "text",
        "id": "contant-heading",
        "label": "Contant heading"
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Button 1 Label"
    },
    {
      "type": "richtext",
      "id": "btn1_content",
      "label": "Button 1 Content"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Button 2 Label"
    },
    {
      "type": "richtext",
      "id": "btn2_content",
      "label": "Button 2 Content"
    },
    {
      "type": "text",
      "id": "btn3_text",
      "label": "Button 3 Label"
    },
    {
      "type": "richtext",
      "id": "btn3_content",
      "label": "Button 3 Content"
    },
	{
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
	  "default": "RED LIGHT AMPLIFIER SERUM"
    },
	{
      "type": "url",
      "id": "btn_url",
      "label": "Button Url"
    }
  ],
  "presets": [
    {
      "name": "Exosome Serum Section"
    }
  ]
}
{% endschema %}

<div class="exosome-section">
  <div class="page-width">
    <div class="details">
      <div class="left-block">
		{% if section.settings.heading != blank %}
        <h2 class="main_title">{{ section.settings.heading }}</h2>
		{% endif %}
		{% if section.settings.description != blank %}
        <div class="description">{{ section.settings.description }}</div>
		{% endif %}
      </div>

      <div class="center-image">
        {% if section.settings.main_image %}
          <img src="{{ section.settings.main_image | image_url }}" alt="{{ section.settings.main_image.alt }}" class="main-image" loading="lazy">
        {% endif %}

        <div class="hotspot-buttons">

			{% if section.settings.btn1_text != blank %}
            <div class="hotspot-btn">
                <button data-target="tab1" class="hot-dot-wrp"><span class="hotspot__dot active"></span></button>
                <p data-contant="tab1" class="contant-heading active">{{ section.settings.btn1_text }}</p>
            </div>
			{% endif %}

			{% if section.settings.btn2_text != blank %}
            <div class="hotspot-btn">
                <button data-target="tab2" class="hot-dot-wrp"><span class="hotspot__dot"></span></button>
                <p data-contant="tab2" class="contant-heading">{{ section.settings.btn2_text }}</p>
            </div>
			{% endif %}

			{% if section.settings.btn3_text != blank %}
            <div class="hotspot-btn">
                <button data-target="tab3" class="hot-dot-wrp"><span class="hotspot__dot"></span></button>
                <p data-contant="tab3" class="contant-heading">{{ section.settings.btn3_text }}</p>
            </div>
			{% endif %}

        </div>
      </div>

      <div class="right-block">
        <div class="contant">
            <h3>{{ section.settings.contant-heading }}</h3>
            <div id="tab1" class="tab-content active">
                {{ section.settings.btn1_content }}
            </div>
            <div id="tab2" class="tab-content">
                {{ section.settings.btn2_content }}
            </div>
            <div id="tab3" class="tab-content">
                {{ section.settings.btn3_content }}
            </div>
        </div>

        {% if section.settings.bottom_image %}
          <img class="bottom-static" src="{{ section.settings.bottom_image | image_url }}" alt="{{ section.settings.bottom_image.alt }}" loading="lazy">
        {% endif %}

		{% if section.settings.btn_url != blank %}
		<div class="exosome-section_btn_wrp">
			<a href="{{ section.settings.btn_url }}" class="common_btn">{{ section.settings.btn_text }}</a>
		</div>
		{% endif %}

      </div>
    </div>
  </div>
</div>

<style>
 @keyframes exosome-zoom-in-zoom-out {
  0% {
    transform: scale(1, 1);
  }
  50% {
    transform: scale(1.5, 1.5);
  }
  100% {
    transform: scale(1, 1);
  }
}
.exosome-section {
	 padding: 96px 0 48px;
}
 .exosome-section .page-width {
	 max-width: 1318px;
	 padding: 0 16px;
}
 .exosome-section .page-width .details {
	 display: flex;
	 flex-wrap:wrap;
	 justify-content: space-between;
	 gap: 20px;
}
 .exosome-section .page-width .details .left-block {
	 width: calc(42% - 13.33px);
	 display: flex;
	 flex-direction: column;
	 justify-content: space-between;
	 gap: 16px;
}
 .exosome-section .page-width .details .left-block h2 {
	 font-weight: 400;
	 text-align: start;
	 text-transform: uppercase;
	 max-width: 370px;
}
 .exosome-section .page-width .details .left-block .description {
	 display: flex;
	 flex-direction: column;
	 gap: 16px;
}
 .exosome-section .page-width .details .left-block .description p {
	 font-size: 20px;
	 font-weight: 400;
	 line-height: 24px;
	 color: #000;
	 margin: 0;
}
 .exosome-section .page-width .details .left-block .description p strong {
	 font-weight: 700;
}
 .exosome-section .page-width .details .center-image {
	 position: relative;
	 width: calc(33% - 13.33px);
	 text-align: center;
}
 .exosome-section .page-width .details .center-image .main-image {
	 width: 100%;
	 height: 100%;
	 object-fit: cover;
}
 .exosome-section .page-width .details .center-image .hotspot-buttons {
	 position: absolute;
	 top: 0;
	 left: 0;
	 width: 100%;
	 height: 100%;
	 pointer-events: none;
}
 .exosome-section .page-width .details .center-image .hotspot-buttons .hotspot-btn {
	 position: absolute;
	 display: flex;
	 align-items: center;
}
 .exosome-section .page-width .details .center-image .hotspot-buttons .hotspot-btn .contant-heading {
	 display: none;
	 font-size: 10px;
	 font-weight: 300;
	 margin: 0;
	 padding: 4px 8px;
	 background: #fff;
	 font-family: var(--argentum);
	 text-transform: uppercase;
	 position: absolute;
	 width: max-content;
	 left: 40px;
}
 .exosome-section .page-width .details .center-image .hotspot-buttons .hotspot-btn .contant-heading.active {
	 display: block;
}
 .exosome-section .page-width .details .center-image .hotspot-buttons .hotspot-btn .hot-dot-wrp {
	 pointer-events: auto;
	 border: none;
	 padding: 5px;
	 cursor: pointer;
	 width: fit-content;
	 background: transparent;
	 color: #000;
	 border-radius: 50px;
	 display: block;
	 box-shadow: 0 0 10px #fff;
	 animation: exosome-zoom-in-zoom-out 5s ease-out infinite;
}
 .exosome-section .page-width .details .center-image .hotspot-buttons .hotspot-btn .hot-dot-wrp .hotspot__dot {
	 display: block;
	 width: 16px;
	 height: 16px;
	 border-radius: 50px;
	 border: 1px solid #fff;
}
 .exosome-section .page-width .details .center-image .hotspot-buttons .hotspot-btn .hot-dot-wrp .hotspot__dot.active {
	 background-color: #fff;
}
 .exosome-section .page-width .details .center-image .hotspot-buttons .hotspot-btn:nth-child(1) {
	 top: 42%;
	 right: 40%;
}
 .exosome-section .page-width .details .center-image .hotspot-buttons .hotspot-btn:nth-child(2) {
	 top: 64%;
	 left: 43%;
}
 .exosome-section .page-width .details .center-image .hotspot-buttons .hotspot-btn:nth-child(2) .contant-heading {
	 right: 40px;
	 left: unset;
}
 .exosome-section .page-width .details .center-image .hotspot-buttons .hotspot-btn:nth-child(3) {
	 bottom: 21%;
	 left: 57%;
}
 .exosome-section .page-width .details .right-block {
	 width: calc(25% - 13.33px);
	 display: flex;
	 flex-direction: column;
	 gap: 24px;
	 justify-content: end;
}
 .exosome-section .page-width .details .right-block .contant h3 {
	 margin: 0 0 25px;
	 font-weight: 500;
	 font-style: Italic;
	 font-size: 30px;
	 line-height: 30px;
}
 .exosome-section .page-width .details .right-block .contant .tab-content {
	 display: none;
	 opacity: 0;
	 transition: opacity 0.4s ease;
}
 .exosome-section .page-width .details .right-block .contant .tab-content p {
	 font-size: 14px;
	 font-size: 14px;
	 line-height: 16px;
	 font-weight: 300;
	 color: #000;
	 font-family: var(--argentum);
	 padding: 0 0 10px;
	 margin: 0 0 10px;
	 border-bottom: 1px solid #bdbdbd;
	 text-transform: uppercase;
}
 .exosome-section .page-width .details .right-block .contant .tab-content p:last-child {
	 margin: 0;
	 border-bottom: 0;
}


 .exosome-section .page-width .details .right-block .contant .tab-content.active {
	 display: block;
	 opacity: 1;
}
 .exosome-section .page-width .details .right-block .bottom-static {
	 width: 100%;
	 max-height: 185px;
	 object-fit: cover;
}

.exosome-section_btn_wrp .common_btn{min-width: 100%;}

 @media (max-width: 1119px) {
	 .exosome-section .page-width .details {
		 flex-wrap: wrap;
		 gap: 16px;
	}
	 .exosome-section .page-width .details .left-block {
		 max-width: 100%;
		 width: 100%;
		 margin: 0 0 5px;
		 gap: 18px;
	}
	 .exosome-section .page-width .details .left-block .description {
		 max-width: 100%;
	}
	 .exosome-section .page-width .details .center-image {
		 width: calc(50% - 8px);
		 max-width: 100%;
	}
	 .exosome-section .page-width .details .right-block {
		 max-width: 100%;
		 margin: 0;
		 width: calc(50% - 8px);
	}
	 .exosome-section .page-width .details .right-block .bottom-static {
		 max-height: 250px;
	}
}
 @media (max-width: 767px) {
	 .exosome-section {
		 padding: 58px 0 28px;
	}
	 .exosome-section .page-width .details .left-block h2 {
		 font-size: 30px!important;
		 max-width: 260px;
	}
	 .exosome-section .page-width .details .left-block .description {
		 gap: 0;
	}
	 .exosome-section .page-width .details .left-block .description p {
		 font-size: 18px;
		 line-height: 20px;
	}

	.exosome-section .page-width .details .left-block .description p br{
	  display: none;
	}

	 .exosome-section .page-width .details .center-image {
		 width: 100%;
	}

	.exosome-section .page-width .details .center-image .hotspot-buttons .hotspot-btn:nth-child(1){
	      top: 44%;
	}

	 .exosome-section .page-width .details .center-image .hotspot-buttons .hotspot-btn:nth-child(2) {
		 top: 65%;
	}
	 .exosome-section .page-width .details .right-block {
		 width: 100%;
		 gap: 36px;
	}
}
 @media (max-width: 475px) {
	 .exosome-section .page-width .details .center-image .hotspot-buttons .hotspot-btn:nth-child(1) {
		 top: 45%;
		 right: 41%;
	}
	 .exosome-section .page-width .details .center-image .hotspot-buttons .hotspot-btn:nth-child(2) {
		 top: 60%;
		 left: 38%;
	}
	 .exosome-section .page-width .details .center-image .hotspot-buttons .hotspot-btn:nth-child(3) {
		 bottom: 20%;
		 left: 55%;
	}
	 .exosome-section .page-width .details .right-block .bottom-static {
		 max-height: 185px;
	}
}
 

</style>

<script>
 document.querySelectorAll('.hotspot-buttons button').forEach((btn) => {
  btn.addEventListener('click', () => {
    const target = btn.getAttribute('data-target');

    document.querySelectorAll('.hotspot__dot').forEach((dot) => {
      dot.classList.remove('active');
    });

    btn.querySelector('.hotspot__dot').classList.add('active');

    document.querySelectorAll('.tab-content').forEach((tab) => {
      tab.classList.remove('active');
    });

    document.querySelectorAll('.contant-heading').forEach((h) => {
      h.classList.remove('active');
    });

    document.getElementById(target).classList.add('active');
    const heading = document.querySelector(`[data-contant="${target}"]`);
    heading.classList.add('active');
  });
});

</script>
