<script>
document.addEventListener('DOMContentLoaded', function() {
  var headerParent = document.querySelectorAll('.sub_menu_block');
  headerParent.forEach(function(element) {
      element.parentNode.classList.add('active');
  });
  
 document.querySelectorAll('.menu_left_drawer_row .menu_left_drawer_sun li, .update_left_menu .update_left_link li').forEach(item => {
    item.addEventListener('click', function () {
        document.querySelectorAll('.menu_left_drawer_scroll > div').forEach(sub => {
            sub.style.display = 'none';
        });
        const targetClasses = Array.from(this.classList).filter(cls => cls !== 'active');
        if (targetClasses.length > 0) {
            const targetClass = targetClasses[0];
            const targetSubmenu = document.querySelector(`.menu_left_drawer_scroll .Sub_${targetClass}`);
            if (targetSubmenu) {
                targetSubmenu.style.display = 'block';
            }
        }
        document.querySelector('body').classList.add('menuOpen');

        document.querySelectorAll('.menu_left_drawer_row .menu_left_drawer_sun li, .update_left_menu .update_left_link li').forEach(el => {
            el.classList.remove('active');
        });
        targetClasses.forEach(targetClass => {
            document.querySelectorAll(`.${targetClass}`).forEach(el => {
                el.classList.add('active');
            });
        });
    });
});

