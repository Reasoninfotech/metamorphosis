    })
  });
   document.querySelector('.update_menu_left .homeBurgerMenu').addEventListener('click', function () {
      document.querySelector('body').classList.add('menuOpen');
      document.querySelector('.menu_left_drawer').classList.add('active');
   });

  document.querySelectorAll('#countrySearch, #mobilecountrySearch').forEach(function(input) {
      input.addEventListener('input', function() {
          var searchTerm = this.value.toLowerCase();
          document.querySelectorAll('#HeaderCountryList .disclosure__item').forEach(function(item) {
              var dataCun = item.getAttribute('data-cun');
              
              if (dataCun) {
                  var dataCunLower = dataCun.toLowerCase();
                  
                  if (dataCunLower.includes(searchTerm)) {
                      item.style.display = '';
                  } else {
                      item.style.display = 'none';
                  }
              } else {
                  item.style.display = 'none';
              }
          });
      });
  });
