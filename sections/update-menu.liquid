const menuItems = document.querySelectorAll(".headerSubMenu.active .menu_click_popup");

menuItems.forEach((item) => {
  item.addEventListener("click", function () {
    const parent = this.closest('.headerSubMenu');
    
    // Toggle data-active on the clicked item’s parent element
    if (parent.hasAttribute("data-active")) {
      parent.removeAttribute("data-active");
    } else {
      parent.setAttribute("data-active", "true");
    }

    // Remove data-active from other menu items
    menuItems.forEach((otherItem) => {
      if (otherItem !== this) {
        otherItem.closest('.headerSubMenu').removeAttribute("data-active");
      }
    });

    // Log for debugging
    console.log(parent);
  });
});



  document.querySelector('.menu_left_drawer_close').addEventListener('click', function () {
    this.parentNode.classList.remove('active');
    document.querySelector('body').classList.remove('menuOpen');
  });
  document.querySelector('.update_menu_shadow').addEventListener('click', function () {
    this.parentNode.classList.remove('active');
    document.querySelector('body').classList.remove('menuOpen');
  });

  
document.querySelector('body').addEventListener('click', function () {
  document.querySelector('.menu_left_drawer').classList.remove('active');
  document.querySelector('body').classList.remove('menuOpen');
});
document.querySelector('.update_menu').addEventListener('click', function (event) {
  event.stopPropagation(); 
