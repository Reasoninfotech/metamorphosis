{% style %}

.exsome_banner_section .exsome_banner_wrp{position: relative;}

.exsome_banner_section .exsome_img figure{margin: 0;}
.exsome_banner_section .exsome_img img{width: 100%;height: 100%;object-fit: cover;vertical-align: middle;}

.exsome_banner_section .desktop_img{height: 100vh!important;max-height: 600px;}
.exsome_banner_section .mobile_img{display: none;}

.exsome_banner_section .exsome_banner_text_bl{position: absolute;bottom: 60px;left: 0;width: 100%;}

.exsome_banner_section .exosme_banner_title{font-size: 60px;line-height: 60px;margin: 0;margin-bottom: 10px;}
.exsome_banner_section .exsome_banner_sub_text{display: block;font-family: var(--argentum);font-size: 20px;line-height: 30px;max-width: 400px;font-weight: 300;color: #000;}

.exsome_banner_section .exsome_btn_wrp{padding-top: 20px;}

.exsome_btn_wrp .common_btn{background: #CA003D!important;color: #fff;min-width: unset;width: 100%;max-width: 360px;}
.exsome_btn_wrp .common_btn:hover{background: transparent!important;color: #fff;}

@media (max-width: 1439px){
  .exsome_banner_section .desktop_img{max-height: 500px;}
}


@media (max-width: 767px){
  
  .exsome_banner_section .desktop_img{display: none;}
  .exsome_banner_section .mobile_img{display: block;max-height: 500px;height: 100vh!important;}

  .exsome_banner_section .exsome_banner_text_bl{text-align: center;}

  .exsome_banner_section .exsome_banner_sub_text{margin: 0 auto;}
  
  .exsome_banner_section .exsome_banner_text_bl{bottom: 30px;}
  .exsome_banner_section .exsome_btn_wrp{padding-top: 16px;}
}

@media (max-width: 575px){
  .exsome_banner_section .exosme_banner_title{font-size: 40px;line-height: 40px;font-style: italic;margin-bottom: 10px;}
  .exsome_banner_section .exsome_banner_text_bl{bottom: 20px;}

  .exsome_banner_section .exsome_banner_sub_text{font-size: 14px;line-height: 18px;max-width: 300px;}

}
  
{% endstyle %}


<div class="exsome_banner_section">
  <div class="exsome_banner_wrp"> 
    
    <div class="exsome_img">
        <figure>  
            {% if section.settings.desktop_image != blank %}
                <img src="{{ section.settings.desktop_image | img_url : "master" }}" {% if section.settings.mobile_image != blank %}class="desktop_img"{% endif %} alt="{{ section.settings.desktop_image.alt }}" loading="lazy"s>
            {% endif %}
            {% if section.settings.mobile_image != blank %}
                <img src="{{ section.settings.mobile_image | img_url : "master" }}" class="mobile_img" alt="{{ section.settings.mobile_image.alt }}" loading="lazy">
            {% endif %}
        </figure>
    </div>

    <div class="exsome_banner_text_bl">
        <div class="page-width">
            {% if section.settings.heading != blank %}
                <h2 class="exosme_banner_title">{{ section.settings.heading }}</h2>
            {% endif %}
            {% if section.settings.sub_text != blank %}
              <span class="exsome_banner_sub_text">{{ section.settings.sub_text }}</span>
            {% endif %}
            {% if section.settings.btn_url != blank %}
                <div class="exsome_btn_wrp">
                <a href="{{ section.settings.btn_url }}" class="common_btn">{{ section.settings.btn_text }}</a>
                </div>
            {% endif %}
        </div>
    </div>

   </div>
</div>



{% schema %}
{
  "name": "Exosome Main Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "Exosome"
    },
    {
      "type": "html",
      "id": "sub_text",
      "label": "Sub Text",
      "default": "THE SCIENCE BEHIND RADIANT, REJUVENATED SKIN"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "DISCOVER OUR EXSOME SERUM"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button Url"
    }
  ],
  "presets": [
    {
      "name": "Exosome Main Banner"
    }
  ]
}
{% endschema %}