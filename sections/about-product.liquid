<script>
document.addEventListener("DOMContentLoaded", function () {

  document.querySelectorAll(".ap_read_more").forEach(btn => {

    btn.addEventListener("click", function () {

      const desc = this.previousElementSibling;
      desc.classList.toggle("active");

      if (desc.classList.contains("active")) {

        // Read Less (Minus icon)
        this.innerHTML = `
          Read less
          <svg xmlns="http://www.w3.org/2000/svg" width="6" height="6" viewBox="0 0 6 6" fill="none">
  <path d="M0 3H6" stroke="#828282" stroke-width="1"/>
</svg>

        `;

      } else {

        // Read More (Plus icon)
        this.innerHTML = `
          Read more
          <svg xmlns="http://www.w3.org/2000/svg" width="6" height="6" viewBox="0 0 6 6" fill="none">
            <path d="M3.52777 6.0059H2.47777V3.5559H-0.000234373V2.4499H2.47777V-0.000102043H3.52777V2.4499H5.99177V3.5559H3.52777V6.0059Z" fill="#828282"/>
          </svg>
        `;

      }

    });

  });

});
</script>
