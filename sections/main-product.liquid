{% style %}
     .product__additional  .image_part{
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
     }
     .product__additional  .image_part img{
    width: calc(25% - 7.5px);
    margin: 0 !important;
     }
  {% if section.settings.show_btn == true %}
    .product__media-list-wrapper{
      position: unset;
    }
    .product_container .action-wrapper {
      border: 2px solid #CA003D;
      width: fit-content;
      margin: 20px 0 0px;
      width: 100%;
    }

    .product_container .action-wrapper .action-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 18px 15px;
        text-decoration: none;
        color: #CA003D;
        letter-spacing: 1px;
        transition: 0.3s ease;
        width: 50%;


        font-weight: 400;
        font-size: 14px;
        line-height: normal;
        text-align: center;
        text-transform: uppercase;
        font-family: var(--argentum);
    }

    .product_container .action-wrapper .left-btn {
        border-right: 2px solid #CA003D;
    }

    .product_container .action-wrapper .action-btn:hover {
        background-color: #CA003D;
        color: #fff;
    }
    .product_container .action-wrapper .action-btn svg{
      width: 18px;
      height: 18px;
    }
    .product_container .action-wrapper .action-btn:hover svg path{
      fill: #fff;
    }

    .product_container .action-wrapper .icon {
        font-size: 18px;
    }
    @media(max-width: 575px){
      .product_container .action-wrapper .action-btn{
        font-size: 14px;
      }
      .product_container .action-wrapper .action-btn svg{
        width: 16px;
        height: 16px;
      }
    }
    @media(max-width: 475px){
      .product_container .action-wrapper .action-btn{
        font-size: 10px;
        padding: 12px 8px;
        gap: 8px;
      }
    }
    @media(max-width: 374px){
      .product_container .action-wrapper{
        flex-direction: column;
      }
      .product_container .action-wrapper .action-btn {
          width: 100%;
          border: none;
      }
      .product_container .action-wrapper .left-btn {
        border-bottom: 2px solid #CA003D;
      }
    }
  {% endif %}
{% endstyle %}
<link rel="stylesheet" href="{{ 'component-deferred-media.css' | asset_url }}" media="all">
<style>
  .flickity-prev-next-button .flickity-button-icon{transform: rotate(270deg);width:40%;left: 30%;}
</style>

<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'copy.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-single.js' | asset_url }}" defer="defer"></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    setTimeout(function () {
      document.querySelectorAll('.product-section .flickity-prev-next-button').forEach(function (btn) {
        if (btn.classList.contains('previous')) {
          btn.innerHTML = `
          <!-- PASTE YOUR LEFT / UP SVG HERE -->
          <svg width="11" class="flickity-button-icon" height="17" viewBox="0 0 11 17" fill="none" xmlns="http://www.w3.org/2000/svg">
			<path  class="arrow" d="M11 6.53875L11 6.94197C9.75597 6.48533 8.64773 5.84063 7.74314 5.04736C6.83854 4.25409 6.15662 3.32893 5.73913 2.32852L5.73913 16.474L5.26087 16.474L5.26087 2.32852C4.84395 3.32959 4.16229 4.25546 3.25766 5.04938C2.35304 5.8433 1.24451 6.48856 -3.86428e-07 6.9456L-3.63792e-07 6.53875C1.58326 5.92124 2.91187 4.98429 3.83994 3.83079C4.76801 2.67729 5.25965 1.35184 5.26087 2.2996e-07L5.73913 2.50865e-07C5.74035 1.35184 6.23199 2.67729 7.16006 3.83079C8.08813 4.98429 9.41674 5.92124 11 6.53875Z" fill="black"/>
			</svg>
		`;
        }

        if (btn.classList.contains('next')) {
          btn.innerHTML = `
          <!-- PASTE YOUR RIGHT / DOWN SVG HERE -->
          <svg width="11" height="17" class="flickity-button-icon" viewBox="0 0 11 17" fill="none" xmlns="http://www.w3.org/2000/svg">
			<path  class="arrow" d="M-1.16152e-06 9.93586L-1.17434e-06 9.53264C1.24403 9.98928 2.35227 10.634 3.25686 11.4272C4.16146 12.2205 4.84338 13.1457 5.26087 14.1461L5.26087 0.000597251L5.73913 0.00059723L5.73913 14.1461C6.15605 13.145 6.83771 12.2192 7.74234 11.4252C8.64696 10.6313 9.75549 9.98605 11 9.52901L11 9.93586C9.41674 10.5534 8.08813 11.4903 7.16006 12.6438C6.23199 13.7973 5.74035 15.1228 5.73913 16.4746L5.26087 16.4746C5.25965 15.1228 4.76801 13.7973 3.83994 12.6438C2.91187 11.4903 1.58326 10.5534 -1.16152e-06 9.93586Z" fill="black"/>
			</svg>
        `;
        }
      });
    }, 300);
  });
</script>
{%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
{%- if first_3d_model -%}
  {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
  <link
    id="ModelViewerStyle"
    rel="stylesheet"
    href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
    media="print"
    onload="this.media='all'"
  >
  <link
    id="ModelViewerOverride"
    rel="stylesheet"
    href="{{ 'component-model-viewer-ui.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
{%- endif -%}

<section class="product_container">
  <div class="product {% if product.media.size > 0 %}row{% else %}product--no-media{% endif %}">
    <div class="product__outer">
      {% if product.media.size > 0 %}
        <div
          class="
            product__media-wrapper
            {% if section.settings.desktop_alignment == 'right' %}product__media-wrapper--desktop-order{% endif %}
            {% if section.settings.mobile_alignment == 'after' %}product__media-wrapper--mobile-order{% endif %}
          "
        >
          {% if section.settings.show_btn == true %}
            <div class="thumbnail_container" style="position: sticky; top: 6.8rem;">
          {% endif %}

          <div class="product__media-list-wrapper">
            <div class="left_side_media">
              <ul class="product__media-sublist carousel carousel-main js-media-sublist no-js-hidden" role="list">
                {%- if product.selected_or_first_available_variant.featured_media != null -%}
                  {%- assign featured_media = product.selected_or_first_available_variant.featured_media -%}
                  <li
                    class="product__media-subitem carousel-cell {% if section.settings.image_fit == 'contain' %} product__media-item--contain{% endif %}"
                    data-media-sub-id="{{ section.id }}-{{ featured_media.id }}"
                  >
                    <div class="product__media">
                      <img
                        src="{{ featured_media | image_url: width: 200 }}"
                        loading="lazy"
                        width="{{ featured_media.preview_image.width | default: 200 }}"
                        height="{{ featured_media.preview_image.height | default: 200 }}"
                        alt="{{ featured_media.preview_image.alt | escape }}"
                      >
                    </div>
                  </li>
                {%- endif -%}

                {%- for media in product.media -%}
                  {%- unless media.id == product.selected_or_first_available_variant.featured_media.id -%}
                    {% unless forloop.index0 == 0 %}
                      <li
                        class="product__media-subitem carousel-cell {% if variant_images contains media.src %} product__media-item--variant{% endif %} {% if section.settings.image_fit == 'contain' %} product__media-item--contain{% endif %}"
                        data-media-sub-id="{{ section.id }}-{{ media.id }}"
                      >
                        <div class="product__media">
                          <img
                            src="{{ media | image_url: width: 200 }}"
                            loading="lazy"
                            width="{{ media.preview_image.width | default: 200 }}"
                            height="{{ media.preview_image.height | default: 200 }}"
                            alt="{{ media.preview_image.alt | escape }}"
                          >
                        </div>
                      </li>
                    {%- endunless -%}
                  {%- endunless -%}
                {%- endfor -%}
              </ul>
            </div>

            <div class="right_side_media">
              <div class="product__media-list-wrapper-outer">
                <ul
                  class="product__media-list carousel carousel-main list-unstyled js-media-list no-js-hidden"
                  role="list"
                >
                  {%- liquid
                    assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'
                    assign media_count = product.media.size
                  -%}

                  {%- if product.selected_or_first_available_variant.featured_media != null -%}
                    {%- assign featured_media = product.selected_or_first_available_variant.featured_media -%}
                    <li
                      class="product__media-item carousel-cell{% if featured_media.media_type != 'image' %} product__media-item--full{% endif %} {% if section.settings.image_fit == 'contain' %} product__media-item--contain{% endif %}"
                      data-media-id="{{ section.id }}-{{ featured_media.id }}"
                    >
                      {% render 'product-thumbnail',
                        media: featured_media,
                        position: 'featured',
                        modal_id: section.id,
                        lazy_load: false
                      %}
                    </li>
                  {%- endif -%}

                  {%- for media in product.media -%}
                    {% unless forloop.index0 == 0 %}
                      {%- unless media.id == product.selected_or_first_available_variant.featured_media.id -%}
                        <li
                          class="product__media-item carousel-cell{% if media.media_type != 'image' %} product__media-item--full{% endif %} {% if variant_images contains media.src %} product__media-item--variant{% endif %} {% if section.settings.image_fit == 'contain' %} product__media-item--contain{% endif %}"
                          data-media-id="{{ section.id }}-{{ media.id }}"
                        >
                          {% render 'product-thumbnail',
                            media: media,
                            position: forloop.index,
                            modal_id: section.id,
                            lazy_load: false
                          %}
                        </li>
                      {%- endunless -%}
                    {%- endunless -%}
                  {%- endfor -%}
                </ul>

                {% if settings.show_dicount_badge == true %}
                  {% if settings.discount_badge_img != blank or product.metafields.custom.dicoount_badge != blank %}
                    <div class="dicoount_badge">
                      <img
                        src="{% if settings.discount_badge_img != blank %}{{ settings.discount_badge_img | image_url: width: 200 }}{% else %}{{ product.metafields.custom.dicoount_badge | image_url: width: 200 }}{% endif %}"
                        alt="{{ product.metafields.custom.dicoount_badge.value | default: 'Discount badge' }}"
                        loading="lazy"
                        width="200"
                        height="200"
                      >
                    </div>
                  {% endif %}
                {% endif %}

                {% if product.media.size > 1 %}
                  <div class="product__media-list-wrapper-outer-arrow product__media-list-wrapper-outer-arrow_prev">
                    <div class="flickity-arrow  flickity-prev">
                      <svg width="63" height="30" viewBox="0 0 63 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M6.31553 15C6.3155 15 6.31545 15 6.31542 15C6.31545 15 6.3155 15 6.31553 15L6.31553 15ZM8.34258 15.7895C13.801 18.332 17.6822 23.692 18.117 30L16.5338 30C15.9291 22.051 9.28778 15.7895 1.18395 15.7895C0.785501 15.7895 0.39058 15.8046 -0.000258161 15.8343L-0.000258015 14.1657C0.390581 14.1954 0.785501 14.2105 1.18395 14.2105C9.28778 14.2105 15.9291 7.94895 16.5338 -5.91431e-06L18.117 -5.77591e-06C17.6822 6.30803 13.801 11.668 8.34257 14.2105L62.3682 14.2105L62.3682 15.7895L8.34258 15.7895Z" fill="currentColor"/>
                      </svg>
                    </div>
                  </div>

                  <div class="product__media-list-wrapper-outer-arrow product__media-list-wrapper-outer-arrow_next">
                    <div class="flickity-arrow  flickity-next">
                      <svg width="63" height="30" viewBox="0 0 63 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M56.0526 15C56.0527 15 56.0527 15 56.0527 15C56.0527 15 56.0527 15 56.0526 15V15ZM54.0256 14.2105C48.5672 11.668 44.6859 6.30803 44.2512 0H45.8343C46.439 7.94895 53.0804 14.2105 61.1842 14.2105C61.5827 14.2105 61.9776 14.1954 62.3684 14.1657V15.8343C61.9776 15.8046 61.5827 15.7895 61.1842 15.7895C53.0804 15.7895 46.439 22.051 45.8343 30H44.2512C44.6859 23.692 48.5672 18.332 54.0256 15.7895H0V14.2105H54.0256Z" fill="currentColor">
                      </svg>
                    </div>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
          {%- if first_3d_model -%}
            <button
              class="button button--full-width product__xr-button"
              type="button"
              aria-label="{{ 'products.product.xr_button_label' | t }}"
              data-shopify-xr
              data-shopify-model3d-id="{{ first_3d_model.id }}"
              data-shopify-title="{{ product.title | escape }}"
              data-shopify-xr-hidden
            >
              {% render 'icon-3d-model' %}
              {{ 'products.product.xr_button' | t }}
            </button>
          {%- endif -%}

          <div
