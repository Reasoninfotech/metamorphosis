      {% endif %}

      <div class="product__info-wrapper">
        <div id="ProductInfo-{{ section.id }}" class="product__info-container">
          {%- assign product_form_id = 'product-form-' | append: section.id -%}

          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'richtext' -%}
                {% if block.settings.text != blank %}
                  <div class="validation">
                    <img src="{{ 'true_green.svg' | asset_url }}" loading="lazy" alt="">
                    {{ block.settings.text }}
                  </div>
                {% endif %}
              {%- when '@app' -%}
                {% render block %}
              {%- when 'text' -%}
                <div class="product__text" {{ block.shopify_attributes }}>
                  {% if block.settings.text != blank %}
                    {% if product.vendor == block.settings.text and settings.enable_vendor_link %}
                      {{ block.settings.text | link_to_vendor: class: 'focus-inset' }}
                    {% else %}
                      {{ block.settings.text }}
                    {% endif %}
                  {% endif %}
                </div>

              {%- when 'title' -%}
                {% if settings.black_friday_special == true %}
                  {% if settings.black_friday_special_text != blank
                    or product.metafields.custom.christmas_text != blank
                  %}
                    <div class="bf_black_bar">
                      {% if settings.Image_black_friday != blank %}
                        <img src="{{ settings.Image_black_friday | image_url: width: 200 }}" loading="lazy" alt="" width="200" height="200">
                      {% else %}
                        {% if product.metafields.custom.christmas_text != blank %}
                          <img
                            src="https://cdn.shopify.com/s/files/1/0693/9849/5445/files/giftbox_2.png?v=1764911691"
                            alt="Metamorphosis Gift Box"
                            loading="lazy"
                            width="300"
                            height="300"
                          >
                        {% endif %}
                      {% endif %}
                      {% if settings.black_friday_special_text != blank
                        or product.metafields.custom.christmas_text != blank
                      %}
                        <div class="bf_text_block">
                          {% if settings.black_friday_special_text != blank -%}
                            {{- settings.black_friday_special_text -}}
                          {%- else -%}
                            {{- product.metafields.custom.christmas_text }}
                          {% endif %}
                        </div>
                      {% endif %}
                    </div>
                  {% endif %}
                {% endif %}

                <div
                  class="
                    product__title__wrapper
                    	{%- if product.available == false %} price--sold-out {% endif -%}
                    {%- if product.compare_at_price > product.price %} price--on-sale {% endif -%}
                  "
                >
                  <h1 class="main_title h2" {{ block.shopify_attributes }}>
                    {% if product.metafields.custom.custom_product_title != blank %}
                      {{ product.metafields.custom.custom_product_title | metafield_text }}
                    {% else %}
                      {{ product.title | escape }}
                    {% endif %}
                  </h1>
                </div>

              {%- when 'tags' -%}
                {%- if product.tags != blank -%}
                  <ul class="product-tags product__tags">
                    {% for tag in product.tags %}
                      <li class="product-tags__tag">
                        {{ tag }}
                        {% render 'icon-checkmark' %}
                      </li>
                    {% endfor %}
                  </ul>
                {%- endif -%}

              {%- when 'description' -%}
                <div class="product_dis" id="product_discription">
                  <div class="product_dis_in">
                    {{ product.description }}
                    <span id="pro_read_dis">Read More +</span>
                  </div>
                </div>
              {%- when 'price' -%}
                <div class="no-js-hidden price-wrapper" id="price-{{ section.id }}" {{ block.shopify_attributes }}>
                  {%- render 'price',
                    product: product,
                    use_variant: true,
                    show_badges: true,
                    price_class: 'price--product'
                  -%}
                  {%- if cart.taxes_included or shop.shipping_policy.body != blank -%}
                    <div class="product__tax caption rte">
                      {%- if cart.taxes_included -%}
                        {{ 'products.product.include_taxes' | t }}
                      {%- endif -%}
                      {%- if shop.shipping_policy.body != blank -%}
                        {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
                {% comment %}
                  <div {{ block.shopify_attributes }} style="margin: 0">
                  	{%- form 'product', product, id: 'product-form-installment', class: 'installment caption-large' -%}
                  		<input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  		{{ form | payment_terms }}
                  	{%- endform -%}
                  </div>
                {% endcomment %}

              {%- when 'sku' -%}
                <p
                  class="product__sku no-js-hidden {% if product.selected_or_first_available_variant.sku.size == 0 %} visibility-hidden{% endif %}"
                  id="Sku-{{ section.id }}"
                  role="status"
                  {{ block.shopify_attributes }}
                >
                  <span class="visually-hidden">{{ 'products.product.sku' | t }}:</span>
                  {{- product.selected_or_first_available_variant.sku -}}
                </p>

              {%- when 'share' -%}
                {%- if block.settings.show_share_facebook
                  or block.settings.show_share_twitter
                  or block.settings.show_share_pinterest
                  or block.settings.show_share_copy
                -%}
                  <div class="share-buttons-wrapper">
                    <div class="share-buttons" aria-label="list">
                      <div class="share-buttons__label">
                        {% render 'icon-share' %}
                        <span class="share-buttons__label-name">{{ 'general.share.share' | t }}</span>
                      </div>

                      <ul class="share-buttons__list">
                        {%- if block.settings.show_share_facebook -%}
                          <li class="share-buttons__item">
                            <a
                              href="https://www.facebook.com/sharer.php?u={{ shop.url | append: product.url }}"
                              class="share-buttons__button facebook-btn"
                              target="_blank"
                            >
                              {% render 'icon-facebook' %}
                              <span class="share-button__name">{{ 'general.share.links.facebook' | t }}</span>
                            </a>
                          </li>
                        {%- endif -%}

                        {%- if block.settings.show_share_twitter -%}
                          <li class="share-buttons__item">
                            <a
                              href="https://twitter.com/share?url={{ shop.url | append: product.url }}&text={{ product.title | escape }}"
                              class="share-buttons__button twitter-btn"
                              target="_blank"
                            >
                              {% render 'icon-twitter' %}
                              <span class="share-button__name">{{ 'general.share.links.twitter' | t }}</span>
                            </a>
                          </li>
                        {%- endif -%}

                        {%- if block.settings.show_share_pinterest -%}
                          <li class="share-buttons__item">
                            <a
                              href="https://pinterest.com/pin/create/bookmarklet/?media={{ product.featured_media | img_url: '1100x1100' }}&url={{ shop.url | append: product.url }}&description={{ product.title | escape }}"
                              class="share-buttons__button pinterest-btn"
                              target="_blank"
                            >
                              {% render 'icon-pinterest' %}
                              <span class="share-button__name">{{ 'general.share.links.pinterest' | t }}</span>
                            </a>
                          </li>
                        {%- endif -%}

                        {%- if block.settings.show_share_copy -%}
                          <li class="share-buttons__item">
                            <a href="{{ shop.url | append: product.url }}" class="share-buttons__button copy-btn">
                              {% render 'icon-copy' %}
                              <span class="share-button__name">{{ 'general.share.links.copy' | t }}</span>
                            </a>
                          </li>
                        {%- endif -%}
                      </ul>
                    </div>
                  </div>
                {%- endif -%}

              {% when 'meta_icon' %}
                <div class="product_meta_icon">
                  {% for block in product.metafields.icon.img %}
                    {% assign i = forloop.index0 %}
                    <div class="meta_icon_block">
                      {% if product.metafields.icon.img[i] != blank %}
                        <figure>
                          <img
                            src="{{ product.metafields.icon.img[i] }}"
                            loading="lazy"
                            alt="{{ product.metafields.icon.text[i] | replace: '<br>', ' ' }}"
                          >
                        </figure>
                      {% endif %}
                      {% if product.metafields.icon.text[i] != blank %}
                        <figcaption>{{ product.metafields.icon.text[i] }}</figcaption>
                      {% endif %}
                    </div>
                  {% endfor %}
                </div>

              {% when 'product_block' %}
                {% assign product_cus = all_products[product.metafields.Product.Block.value] %}
                {% if product_cus != blank %}
                  <div class="product_related_B0lcok">
                    {% if block.settings.routine_title != blank %}
                      <div class="product_routine_title">{{ block.settings.routine_title }}</div>
                    {% endif %}
                    <div class="product_select_block">
                      <div class="product_select_block_row">
                        <figure>
                          <a href="{{ product_cus.url }}">
                            {% if product.metafields.Product.block_img != blank %}
                              <img
                                src="{{ product.metafields.Product.block_img }}"
                                alt="{{ product_cus.metafields.Product.list_title }}"
                              >
                            {% else %}
                              <img
                                src="{{ product_cus.featured_media | img_url : "medium" }}"
                                class="dddd"
                                alt="{{ product_cus.featured_media.alt }}"
                              >
                            {% endif %}
                          </a>
                        </figure>
                        <div class="product_title_with_price">
                          <h5 class="product_title ">
                            {% if product_cus.metafields.Product.list_title != blank %}
                              {{ product_cus.metafields.Product.list_title }}
                            {% else %}
                              {{ product_cus.title }}
                            {% endif %}
                          </h5>
                          <div class="product_meta_compare_block">
                            <span class="product-select-price-money product_meta_compare_price"
                              ><s>{{ product_cus.compare_at_price | money }}</s></span
                            >
                            {% if product_cus.handle != 'hydrogel-pink-lip' %}
                              <span class="product-select-price-money">{{ product_cus.price | money }}</span>
                            {% else %}
                              <span
                                class="product-select-price-money compare-price"
                                style="
                                  text-decoration: line-through;font-weight: 400;
                                  font-size: 22px;
                                "
                              >
                                {{- product_cus.price | money -}}
                              </span>
                              <span class="product-select-price-money"
                                >-
                                {{- product_cus.price | times: 0 | money -}}
                              </span>
                            {% endif %}
                          </div>
                        </div>
                      </div>
                      {%- liquid
                        assign gift_card_recipient_feature_active = false
                        if product_cus.gift_card?
                          assign gift_card_recipient_feature_active = true
                        endif
                        assign show_dynamic_checkout = false
                        if gift_card_recipient_feature_active == false
                          assign show_dynamic_checkout = true
                        endif
                      -%}
                      <product-form class="product-form" data-hide-errors="{{ gift_card_recipient_feature_active }}">
                        <div class="product-form__error-message-wrapper" role="alert" hidden>
                          <svg
                            aria-hidden="true"
                            focusable="false"
                            role="presentation"
                            class="icon icon-error"
                            viewBox="0 0 13 13"
                          >
                            <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/></circle>
                            <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/></circle>
                            <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/></path>
                            <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7"></path>
                          </svg>
                          <span class="product-form__error-message"></span>
                        </div>
                        {%- assign product_form_id = 'product-form-' | append: section.id -%}
                        {%- form 'product',
                          product_cus,
                          id: product_form_id,
                          class: 'form',
                          novalidate: 'novalidate',
                          data-type: 'add-to-cart-form'
                        -%}
                          <input
                            type="hidden"
                            name="id"
                            value="{{ product_cus.selected_or_first_available_variant.id }}"
                            disabled
                          >

                          <div class="product-form__buttons" style="margin:0;">
                            <button
                              id="ProductSubmitButton-{{ section.id }}"
                              type="submit"
                              name="add"
                              class="product-form__submit common_btn product-section__button button--primary-size button--arrow button--primary"

                              {% if block.settings.show_dynamic_checkout and product_cus.selling_plan_groups == empty %}
                                button--secondary
                              {% else %}
                                button--primary
                              {% endif %}

