    </div>
  </product-modal>
</section>

{% javascript %}
  class ProductModal extends ModalDialog {
    constructor() {
      super();
    }

    hide() {
      super.hide();
      window.pauseAllMedia();
    }

    show(opener) {
      super.show(opener);
      this.showActiveMedia();
    }

    showActiveMedia() {
      this.querySelectorAll(
        `[data-media-id]:not([data-media-id="${this.openedBy.getAttribute('data-media-id')}"])`
      ).forEach((element) => {
        element.classList.remove('active');
      });
      const activeMedia = this.querySelector(`[data-media-id="${this.openedBy.getAttribute('data-media-id')}"]`);
      activeMedia.classList.add('active');
      activeMedia.scrollIntoView();

      if (
        activeMedia.nodeName == 'DEFERRED-MEDIA' &&
        activeMedia.querySelector('template')?.content?.querySelector('.js-youtube')
      )
        activeMedia.loadContent();
    }
  }

  class ProductRecommendations extends HTMLElement {
    constructor() {
      super();

      const handleIntersection = (entries, observer) => {
        if (!entries[0].isIntersecting) return;
        observer.unobserve(this);

        fetch(this.dataset.url)
          .then((response) => response.text())
          .then((text) => {
            const html = document.createElement('div');
            html.innerHTML = text;
            const recommendations = html.querySelector('product-recommendations--single');
            if (recommendations && recommendations.innerHTML.trim().length) {
              this.innerHTML = recommendations.innerHTML;
            }
          })
          .catch((e) => {
            console.error(e);
          });
      };

      new IntersectionObserver(handleIntersection.bind(this), { rootMargin: '0px 0px 200px 0px' }).observe(this);
    }
  }

  customElements.define('product-modal', ProductModal);
  customElements.define('product-recommendations--single', ProductRecommendations);

  $(document).ready(function () {
    if ($('.product-section') && $('.product-section').length > 0) {
      document.querySelectorAll('.product-section .product__media-list').forEach((elem, index) => {
        var slider = new Flickity(elem, {
          pageDots: true,
          prevNextButtons: false,
          adaptiveHeight: true,
          wrapAround: true,
          on: {
            select: function (index) {
              let slides = $('.product-section .product__media-list .product__media-item');

              var iframe = $(slides[index]).find('iframe');

              var allIframes = document.querySelectorAll('.product-section .product__media-list iframe');
              //$(".product-section .product__media-list").find("iframe");
              var video = $(slides[index]).find('video');
              var allVideos = $('.product-section .product__media-list').find('video');

              if (video && video.length > 0) {
                video.get(0).play();
              } else if (allVideos && allVideos.length > 0) {
                allVideos.get(0).pause();
              }

              if (iframe && iframe.length > 0) {
                if (iframe[0].classList.contains('js-youtube')) {
                  iframe[0].contentWindow.postMessage(JSON.stringify({ event: 'command', func: 'playVideo' }), '*');
                } else {
                  iframe[0].contentWindow.postMessage('{"method":"play"}', '*');
                }
              } else if (allIframes && allIframes.length > 0) {
                allIframes.forEach((video) => {
                  if (video.classList.contains('js-youtube')) {
                    video.contentWindow.postMessage(JSON.stringify({ event: 'command', func: 'pauseVideo' }), '*');
                  } else {
                    video.contentWindow.postMessage('{"method":"pause"}', '*');
                  }
                });
              } else {
                return false;
              }
            },
          },
        });

        elem.parentElement
          .querySelector('.product-section .product__media-list-wrapper-outer-arrow_prev')
          .addEventListener('click', function () {
            slider.previous();
          });
        elem.parentElement
          .querySelector('.product-section .product__media-list-wrapper-outer-arrow_next')
          .addEventListener('click', function () {
            slider.next();
          });
      });

      // document.querySelectorAll(".product-section .product__media-sublist").forEach((elem, index) => {

      //    var cellCount = elem.querySelectorAll(".carousel-cell").length;

      // 	var slider = new Flickity(elem, {
      // 		asNavFor: document.querySelectorAll(".product-section .product__media-list")[index],
      // 		contain: true,
      // 		pageDots: true,
      // 		prevNextButtons: cellCount > 5,
      // 		cellAlign: "left",
      // 	})
      // });

      document.querySelectorAll('.product-section .product__media-sublist').forEach((elem, index) => {
        var cellCount = elem.querySelectorAll('.carousel-cell').length;
        var screenWidth = window.innerWidth;
        var showArrows = false;

        if (screenWidth > 1611) {
          showArrows = cellCount > 5;
        } else if (screenWidth > 1199) {
          showArrows = cellCount > 3;
        } else {
          showArrows = cellCount > 3;
        }

        var slider = new Flickity(elem, {
          asNavFor: document.querySelectorAll('.product-section .product__media-list')[index],
          contain: true,
          pageDots: true,
          prevNextButtons: showArrows,
          cellAlign: 'left',
        });
      });

      /*
