  document.addEventListener('DOMContentLoaded', function () {
    const mediaSublist = document.querySelector('.product__media-sublist');
    if (!mediaSublist) return;

    /* PREVIOUS arrow */
    const prevBtn = mediaSublist.querySelector('.flickity-prev-next-button.previous .flickity-button-icon');

    if (prevBtn) {
      prevBtn.outerHTML = `
