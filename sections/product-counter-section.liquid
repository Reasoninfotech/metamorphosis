$(document).ready(function() {
  if ($('.counter-sec-number span').length > 0) {
    function inVisible(element) {
      var WindowTop = $(window).scrollTop();
      var WindowBottom = WindowTop + $(window).height();
      var ElementTop = element.offset().top;
      var ElementBottom = ElementTop + element.height();
      if ((ElementBottom <= WindowBottom) && ElementTop >= WindowTop) {
        animate(element);
      }
    }

    function animate(element) {
      if (!element.hasClass('animated')) {
        element.addClass('animated');
        var targetValue = parseInt(element.text());
        var startValue = 0;

        $({ Counter: startValue }).animate({ Counter: targetValue }, {
          duration: 2500,
          easing: 'swing',
          step: function () {
            let currentValue = Math.round(this.Counter / 10) * 10; 
            element.text(currentValue);
          },
          complete: function () {
            element.text(targetValue);
          }
        });
      }
    }

    $(window).scroll(function() {
      $(".counter-sec-number span").each(function() {
        inVisible($(this));
      });
    });
    $(window).scroll();
  }
});
  
</script>  

{% schema %}
  {
    "name": "Counter Section",
    "settings": [
      {
        "type": "checkbox",
        "id": "padding_top",
        "label": "Padding Top",
      },
      {
        "type": "checkbox",
        "id": "padding_bottom",
        "label": "Padding Bottom",
      },
      {
        "type":"color",
        "id":"background",
        "label":"Background",
        "default":"#202020"
      },
      {
        "type":"text",
        "id":"title",
        "label":"Title",
      },
      {
        "type": "richtext",
        "id": "sub_text",
        "label": "Sub text"
      },
      {
        "type": "checkbox",
        "id": "use-meta",
        "label":"Use meta field value",
        "default": false
      },
      {
        "type": "richtext",
        "id": "bottom_text",
        "label": "Bottom Text",
        "default": "<p>Based on an independent 84 day clinical study with once daily use. Individual results may vary. Not intended to diagnose, treat, cure or prevent any disease.</p>"
      }
    ],
    "blocks":[
    ],
    
    "presets":[
      {
        "name":"Counter Section"
      }
    ]
  }
{% endschema %}