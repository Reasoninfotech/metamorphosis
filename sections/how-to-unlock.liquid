<script>
document.addEventListener("DOMContentLoaded", function () {
    const buttons = document.querySelectorAll(".left_tab_button");
    const contents = document.querySelectorAll(".right_tab_content");

    if (buttons.length && contents.length) {
        contents[0].classList.add("active");
        buttons[0].classList.add("active"); // first button active

        buttons.forEach((btn) => {
            btn.addEventListener("click", () => {
                const index = btn.dataset.index;

                // remove active from all buttons
                buttons.forEach((b) => b.classList.remove("active"));
                // add active to clicked button
                btn.classList.add("active");

                // manage right content
                contents.forEach((c) => c.classList.remove("active"));
                document
                    .querySelector(`.right_tab_content[data-index="${index}"]`)
                    .classList.add("active");
            });
        });
    }
});
</script>

