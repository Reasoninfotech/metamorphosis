<section class="how_to_Unlock {{ section.settings.custom_class }}" style="background-image: url({{ section.settings.background_img | img_url: "master" }});">
    <div class="page-width">
    <div class="how_to_Unlock_werp">

        <!-- LEFT TABS -->
        <div class="how_to_Unlock_block">
            {% if section.settings.sub_text != blank %}
                <h3>{{ section.settings.sub_text }}</h3>
            {% endif %}
            
            {% if section.settings.heading != blank %}
                <h4>{{ section.settings.heading }}</h4>
            {% endif %}

            <div class="left_tab_buttons">
                {% assign index = 0 %}
                {% for block in section.blocks %}
                    {% if block.type == 'left_item' %}
                        <button class="left_tab_button" data-index="{{ index }}">
                            <h5>{{ block.settings.item_title }}</h5>
                            {{ block.settings.item_sub_text }}
                        </button>
                        {% assign index = index | plus: 1 %}
                    {% endif %}
                {% endfor %}
            </div>
        </div>

        <!-- RIGHT TAB CONTENT -->
        <div class="how_to_Unlock_tab">
            {% assign index = 0 %}
            {% for block in section.blocks %}
                {% if block.type == 'right_item' %}
                    <div class="how_to_Unlock_mobile_item_rwap">
                      <div class="how_to_Unlock_mobile_item">
                                            <h5>{{ block.settings.item_title }}</h5>
                                                {{ block.settings.item_sub_text }}
                                        </div>
                    <div class="right_tab_content" data-index="{{ index }}">
                      

                            {%- assign titles = "1,2,3,4" | split: "," -%}
                            {%- for i in titles -%}
                                {%- assign title_key = "tab_title_" | append: i -%}
                                {%- assign text_key = "tab_sub_text_" | append: i -%}
                                {% if block.settings[title_key] != blank %}
                                    <div class="how_to_Unlock_tab_block">
                                    <h5>{{ block.settings[title_key] }}</h5>
                                    <p>{{ block.settings[text_key] }}</p>
                                    </div>
                                {% endif %}
                            {%- endfor -%}

                        
                    </div>
                    </div>
                    {% assign index = index | plus: 1 %}
                {% endif %}
            {% endfor %}
        </div>
    </div>
    </div>
</section>

