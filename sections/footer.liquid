{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="{{ 'component-newsletter.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-accordion.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-list-payment.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-list-social.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-rte.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'disclosure.css' | asset_url }}" media="print" onload="this.media='all'">

<noscript>{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-accordion.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-list-social.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-rte.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'disclosure.css' | asset_url | stylesheet_tag }}</noscript>

<footer class="footer color-{{ section.settings.color_scheme }} {% if section.settings.show_border %} footer--border {% endif %}" style="background-image: url('{{ section.settings.background-img | img_url : 'master' }};">
  <div class="footer__content-top container">
    {%- if section.blocks.size > 0 -%}
      <div class="footer__blocks-container">
        <div class="footer__blocks-wrapper">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'link_list' -%}
                {%- if block.type == 'link_list' and block.settings.heading != blank -%}
                  <div class="accordion">
                    <details>
                      <summary>
                        <h2 class="h4 accordion__title">{{ block.settings.heading | escape }}</h2>
                        {% render 'icon-caret' %}
                      </summary>
                      {%- if block.settings.menu != blank -%}
                        <ul class="footer-block__details-content list-unstyled">
                          {%- for link in block.settings.menu.links -%}
                            <li>
                              <a
                                href="{{ link.url }}"
                                class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                              >
                                {{ link.title }}
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}
                    </details>
                  </div>
                {%- endif -%}

                <div
                  class="footer-block {% if block.type == 'link_list' and block.settings.heading != blank %} footer-block--menu{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.heading != blank -%}
                    <h2 class="footer-block__heading">{{- block.settings.heading | escape -}}</h2>
                  {%- endif -%}

                  {%- if block.settings.menu != blank -%}
                    <ul class="footer-block__details-content list-unstyled">
                      {%- for link in block.settings.menu.links -%}
                        <li class="cus_{{ forloop.index }}">
                          <a
                            href="{{ link.url }}"
                            class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                          >
                            {{ link.title }}
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </div>
                <div class="footer__column footer__column--social">
                <ul class="footer__list-social list-unstyled list-social" role="list">
                  {%- if settings.social_twitter_link != blank -%}
                    <li class="list-social__item">
                      <a
                        {% if settings.new_tab %}
                          target="_blank"
                        {% endif %}
                        href="{{ settings.social_twitter_link }}"
                        class="link link--text list-social__link"
                        aria-describedby="a11y-external-message"
                      >
                        <span>{{ 'general.social.links.twitter' | t }}</span>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if settings.social_facebook_link != blank -%}
                    <li class="list-social__item">
                      <a
                        {% if settings.new_tab %}
                          target="_blank"
                        {% endif %}
                        href="{{ settings.social_facebook_link }}"
                        rel="nofollow"
                        class="link link--text list-social__link"
                        aria-describedby="a11y-external-message"
                      >
                        <span>{{ 'general.social.links.facebook' | t }}</span>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if settings.social_pinterest_link != blank -%}
                    <li class="list-social__item">
                      <a
                        {% if settings.new_tab %}
                          target="_blank"
                        {% endif %}
                        href="{{ settings.social_pinterest_link }}"
                        class="link link--text list-social__link"
                        aria-describedby="a11y-external-message"
                      >
                        <span>{{ 'general.social.links.pinterest' | t }}</span>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if settings.social_instagram_link != blank -%}
                    <li class="list-social__item">
                      <a
                        {% if settings.new_tab %}
                          target="_blank"
                        {% endif %}
                        href="{{ settings.social_instagram_link }}"
                        rel="nofollow"
                        class="link link--text list-social__link"
                        aria-describedby="a11y-external-message"
                      >
                        <span>{{ 'general.social.links.instagram' | t }}</span>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if settings.social_tiktok_link != blank -%}
                    <li class="list-social__item">
                      <a
                        {% if settings.new_tab %}
                          target="_blank"
                        {% endif %}
                        href="{{ settings.social_tiktok_link }}"
                        rel="nofollow"
                        class="link link--text list-social__link"
                        aria-describedby="a11y-external-message"
                      >
                        <span>{{ 'general.social.links.tiktok' | t }}</span>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if settings.social_tumblr_link != blank -%}
                    <li class="list-social__item">
                      <a
                        {% if settings.new_tab %}
                          target="_blank"
                        {% endif %}
                        href="{{ settings.social_tumblr_link }}"
                        class="link link--text list-social__link"
                        aria-describedby="a11y-external-message"
                      >
                        {%- render 'icon-tumblr' -%}
                        <span class="visually-hidden">{{ 'general.social.links.tumblr' | t }}</span>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if settings.social_snapchat_link != blank -%}
                    <li class="list-social__item">
                      <a
                        {% if settings.new_tab %}
                        target="_blank"
                        {% endif %}
                        href="{{ settings.social_snapchat_link }}"
                        class="link link--text list-social__link"
                        aria-describedby="a11y-external-message"
                      >
                        <span>{{ 'general.social.links.snapchat' | t }}</span>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if settings.social_youtube_link != blank -%}
                    <li class="list-social__item">
                      <a
                        {% if settings.new_tab %}
                          target="_blank"
                        {% endif %}
                        href="{{ settings.social_youtube_link }}"
                        rel="nofollow"
                        class="link link--text list-social__link"
                        aria-describedby="a11y-external-message"
                      >
                        <span>{{ 'general.social.links.youtube' | t }}</span>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if settings.social_vimeo_link != blank -%}
                    <li class="list-social__item">
                      <a
                        {% if settings.new_tab %}
                          target="_blank"
                        {% endif %}
                        href="{{ settings.social_vimeo_link }}"
                        class="link link--text list-social__link"
                        aria-describedby="a11y-external-message"
                      >
                        <span>{{ 'general.social.links.vimeo' | t }}</span>
                      </a>
                    </li>
                  {%- endif -%}
                </ul>
              </div>

              {%- when 'logo_info' -%}
                <div class="footer-block footer-block--logo"  {{ block.shopify_attributes }}>
                  <a href="{{ routes.root_url }}" class="footer__logo-link link link--text focus-inset">
                    {%- if block.settings.logo != blank -%}
                      {%- assign image_size = block.settings.logo_width | append: 'x' -%}
                      <img
                        srcset="{{ block.settings.logo | img_url: image_size }} 1x, {{ block.settings.logo | img_url: image_size, scale: 2 }} 2x"
                        src="{{ block.settings.logo | img_url: image_size }}"
                        loading="lazy"
                        class="footer__logo"
                        width="{{ block.settings.logo_width }}"
                        height="{{ block.settings.logo.height }}"
                        alt="{{ block.settings.logo.alt | default: shop.name | escape }}"
                      >
                    {%- else -%}
                      <span class="h2">{{ shop.name }}</span>
                    {%- endif -%}
                  </a>
                  {%- if block.settings.logo_text != blank -%}
                    <div class="footer__text">{{- block.settings.logo_text -}}</div>
                  {%- endif -%}
                </div>

              {%- when 'localization' -%}
                {%- if block.settings.enable_country_selector
                  or block.settings.enable_language_selector
                  or block.settings.enable_subscribe_selector
                -%}
                {%- endif -%}
              
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>

  <div class="footer__content-middle pb_90">
    <div class="page-width">
      <div class="footer__content-middle-container">
        <div class="footer__content-middle-main">
          <div class="footer__copyright">
            <small class="footer-copyright-text">DESIGNED IN THE USA</small>
            <small class="copyright__content">Metamorphosis Light Therapy, LLC &copy; {{ 'now' | date: '%Y' -}}. All Rights Reserved.</small>
          </div>

          {% comment %}  
          {%- if section.settings.bottom_menu != blank -%}
            <div class="footer__column footer__column--menu">
              <ul class="footer__bottom-menu list-unstyled">
                {%- for link in section.settings.bottom_menu.links -%}
                  <li>
                    <a
                      href="{{ link.url }}"
                      class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                    >
                      {{ link.title }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
          {% endcomment %}

          
          {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
            <div class="footer__follow-on-shop">
              {% comment %} TODO: enable theme-check once `login_button` is accepted as valid filter {% endcomment %}
              {% # theme-check-disable %}
              {{ shop | login_button: action: 'follow' }}
              {% # theme-check-enable %}
            </div>
          {%- endif -%}
          {%- if section.settings.payment_enable -%}
            <div class="footer__column footer__column--payment">
              <div class="footer__payment">
                <h2 class="caption-large" id="FooterCountryLabel">{{ 'sections.footer.payment' | t }}</h2>
                <ul class="list list-payment" role="list">
                  {%- for type in shop.enabled_payment_types -%}
                    <li class="list-payment__item">
                      {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>
      {%- if section.settings.show_policy -%}
        <ul class="policies list-unstyled">
          {%- for policy in shop.policies -%}
            {%- if policy != blank -%}
              <li>
                <small class="copyright__content"
                  ><a href="{{ policy.url }}">{{ policy.title }}</a></small
                >
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
      {% if section.settings.cus_text != blank %}
        <div class="footer-cus-text">{{ section.settings.cus_text }}</div>
      {% endif %} 
    </div>
  </div>
</footer>

{% javascript %}
  class LocalizationForm extends HTMLElement {
    constructor() {
      super();
      this.elements = {
        input: this.querySelector('input[name="locale_code"], input[name="country_code"]'),
        button: this.querySelector('button'),
        panel: this.querySelector('ul'),
      };
      this.elements.button.addEventListener('click', this.openSelector.bind(this));
      this.elements.button.addEventListener('focusout', this.closeSelector.bind(this));
      this.addEventListener('keyup', this.onContainerKeyUp.bind(this));

      this.querySelectorAll('a').forEach((item) => item.addEventListener('click', this.onItemClick.bind(this)));
    }

    hidePanel() {
      this.elements.button.setAttribute('aria-expanded', 'false');
      this.elements.panel.setAttribute('hidden', true);
    }

    onContainerKeyUp(event) {
      if (event.code.toUpperCase() !== 'ESCAPE') return;

      this.hidePanel();
      this.elements.button.focus();
    }

    onItemClick(event) {
      event.preventDefault();
      this.elements.input.value = event.currentTarget.dataset.value;
      this.querySelector('form')?.submit();
    }

    openSelector() {
      this.elements.button.focus();
      this.elements.panel.toggleAttribute('hidden');
      this.elements.button.setAttribute(
        'aria-expanded',
        (this.elements.button.getAttribute('aria-expanded') === 'false').toString()
      );
    }

    closeSelector(event) {
      const shouldClose = event.relatedTarget && event.relatedTarget.nodeName === 'BUTTON';
      if (event.relatedTarget === null || shouldClose) {
        this.hidePanel();
      }
    }
  }

  customElements.define('localization-form', LocalizationForm);
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.footer.name",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Quick links",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label",
          "info": "t:sections.footer.blocks.link_list.settings.heading.info"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label",
          "info": "t:sections.footer.blocks.link_list.settings.menu.info"
        }
      ]
    },
    {
      "type": "logo_info",
      "name": "t:sections.footer.blocks.logo_info.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "t:sections.footer.blocks.logo_info.settings.logo.label"
        },
        {
          "type": "range",
          "id": "logo_width",
          "min": 50,
          "max": 250,
          "step": 10,
          "default": 100,
          "unit": "t:sections.footer.blocks.logo_info.settings.logo_width.unit",
          "label": "t:sections.footer.blocks.logo_info.settings.logo_width.label"
        },
        {
          "type": "inline_richtext",
          "id": "logo_text",
          "default": "Description for site",
          "label": "t:sections.footer.blocks.logo_info.settings.logo_text.label"
        }
      ]
    },
    {
      "type": "localization",
      "name": "t:sections.footer.blocks.localization.name",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "t:sections.footer.blocks.localization.settings.header__3.content",
          "info": "t:sections.footer.blocks.localization.settings.header__4.info"
        },
        {
          "type": "checkbox",
          "id": "enable_country_selector",
          "default": false,
          "label": "t:sections.footer.blocks.localization.settings.enable_country_selector.label"
        },
        {
          "type": "header",
          "content": "t:sections.footer.blocks.localization.settings.header__5.content",
          "info": "t:sections.footer.blocks.localization.settings.header__6.info"
        },
        {
          "type": "checkbox",
          "id": "enable_language_selector",
          "default": false,
          "label": "t:sections.footer.blocks.localization.settings.enable_language_selector.label"
        },
        {
          "type": "header",
          "content": "t:sections.footer.blocks.localization.settings.header__7.content"
        },
        {
          "type": "checkbox",
          "id": "enable_subscribe_selector",
          "default": false,
          "label": "t:sections.footer.blocks.localization.settings.enable_subscribe_selector.label"
        },
        {
          "type": "text",
          "id": "subscribe_heading",
          "default": "Subscribe to our emails",
          "label": "t:sections.footer.blocks.localization.settings.subscribe_heading.label"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "background-img",
      "label": "Background Image"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "background-1",
          "label": "t:sections.footer.settings.color_scheme.options__1.label"
        },
        {
          "value": "background-2",
          "label": "t:sections.footer.settings.color_scheme.options__2.label"
        },
        {
          "value": "background-5",
          "label": "t:sections.footer.settings.color_scheme.options__3.label"
        },
        {
          "value": "background-3",
          "label": "t:sections.footer.settings.color_scheme.options__4.label"
        },
        {
          "value": "background-4",
          "label": "t:sections.footer.settings.color_scheme.options__5.label"
        },
        {
          "value": "inverse",
          "label": "t:sections.footer.settings.color_scheme.options__6.label"
        }
      ],
      "default": "background-3",
      "label": "t:sections.footer.settings.color_scheme.label"
    },
    {
      "type": "checkbox",
      "id": "show_border",
      "default": false,
      "label": "t:sections.footer.settings.show_border.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__2.content",
      "info": "t:sections.footer.settings.header__2.info"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "default": false,
      "label": "t:sections.footer.settings.show_social.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__9.content",
      "info": "t:sections.footer.settings.header__9.info"
    },
    {
      "type": "checkbox",
      "id": "enable_follow_on_shop",
      "default": false,
      "label": "t:sections.footer.settings.enable_follow_on_shop.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__7.content"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": false,
      "label": "t:sections.footer.settings.payment_enable.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__8.content",
      "info": "t:sections.footer.settings.header__8.info"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "default": false,
      "label": "t:sections.footer.settings.show_policy.label"
    },
    {
     "type": "richtext",
     "id": "cus_text",
     "label": "Custom Text"
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "logo_info"
      },
      {
        "type": "link_list"
      },
      {
        "type": "localization"
      }
    ]
  }
}
{% endschema %}
