{%- liquid
  assign lcp_block = nil
  for block in section.blocks
    if block.disabled
      continue
    endif
    if block.settings.image != blank or block.settings.image1 != blank
      assign lcp_block = block
      break
    endif
  endfor
-%}
{%- if lcp_block -%}
  {%- if lcp_block.settings.image != blank -%}
    <link rel="preload" as="image" href="{{ lcp_block.settings.image | image_url: width: 1920 }}" media="(min-width: 768px)" fetchpriority="high">
  {%- endif -%}
  {%- if lcp_block.settings.image1 != blank -%}
    <link rel="preload" as="image" href="{{ lcp_block.settings.image1 | image_url: width: 860 }}" media="(max-width: 767px)" fetchpriority="high">
  {%- endif -%}
{%- endif -%}

{{ 'home-banner-section.css' | asset_url | stylesheet_tag }}

<section class="header-slider bg-gray-100{% if section.settings.padding_bottom == true %} pb_90{% endif %}">
  <div class="header-slider-desktop swiper">
    <div class="swiper-wrapper">
      {%- assign hero_lcp_done = false -%}
      {% for block in section.blocks %}
        {%- if block.disabled -%}{%- continue -%}{%- endif -%}
        <div id="slide--{{ block.id }}" class="swiper-slide d-flex align-items-center {% if block.settings.custom_class != blank %}{{ block.settings.custom_class }}{% endif %}">
          <style> 
            #slide--{{ block.id }}.swiper-slide{
             background-color:{{ block.settings.bg_color}} ! important;
            }
          </style>
          <div class="row h-100 no-gutter w-100 flex-lg-row flex-column home-img-block">
            <div class="images">
              {% if block.settings.image != blank %}
                {%- if hero_lcp_done == false -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 1920 }}"
                    srcset="{{ block.settings.image | image_url: width: 750 }} 750w, {{ block.settings.image | image_url: width: 1200 }} 1200w, {{ block.settings.image | image_url: width: 1920 }} 1920w"
                    sizes="100vw"
                    alt="{{ block.settings.image.alt | escape }}"
                    fetchpriority="high"
                    decoding="async"
                    width="1920"
                    height="800"
                    class="desktop-img"
                  >
                {%- else -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 1920 }}"
                    srcset="{{ block.settings.image | image_url: width: 750 }} 750w, {{ block.settings.image | image_url: width: 1200 }} 1200w, {{ block.settings.image | image_url: width: 1920 }} 1920w"
                    sizes="100vw"
                    alt="{{ block.settings.image.alt | escape }}"
                    loading="lazy"
                    decoding="async"
                    width="1920"
                    height="800"
                    class="desktop-img"
                  >
                {%- endif -%}
              {% endif %}
              {% if block.settings.image1 != blank %}
                {%- if hero_lcp_done == false -%}
                  <img
                    src="{{ block.settings.image1 | image_url: width: 860 }}"
                    srcset="{{ block.settings.image1 | image_url: width: 400 }} 400w, {{ block.settings.image1 | image_url: width: 600 }} 600w, {{ block.settings.image1 | image_url: width: 860 }} 860w"
                    sizes="100vw"
                    alt="{{ block.settings.image1.alt | escape }}"
                    fetchpriority="high"
                    decoding="async"
                    width="860"
                    height="600"
                    class="mobile-img"
                  >
                {%- else -%}
                  <img
                    src="{{ block.settings.image1 | image_url: width: 860 }}"
                    srcset="{{ block.settings.image1 | image_url: width: 400 }} 400w, {{ block.settings.image1 | image_url: width: 600 }} 600w, {{ block.settings.image1 | image_url: width: 860 }} 860w"
                    sizes="100vw"
                    alt="{{ block.settings.image1.alt | escape }}"
                    loading="lazy"
                    decoding="async"
                    width="860"
                    height="600"
                    class="mobile-img"
                  >
                {%- endif -%}
              {% endif %}
              {%- if hero_lcp_done == false -%}{%- assign hero_lcp_done = true -%}{%- endif -%}
            </div>

            <div class="slider_content">
              <div class="page-width">
                <div class="slider-content-wrap">
                  {% if block.settings.star_text != blank %}
                  <div class="star-rating">
                    <div class="star_rating_block">
                      {% for i in (1..5) %}
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                            <path d="M13.0771 15.056C13.1063 15.2047 13.0576 15.3533 12.9309 15.4425C12.814 15.5317 12.6581 15.5417 12.5314 15.4624L8 12.7366L3.47837 15.4723C3.35169 15.5516 3.19577 15.5417 3.07883 15.4525C2.96189 15.3632 2.90342 15.2146 2.93265 15.0659L4.08255 9.84239L0.126125 6.29398C0.0189316 6.19486 -0.0297929 6.03627 0.0189316 5.8975C0.0676561 5.75874 0.184595 5.64971 0.330768 5.6398L5.57352 5.1343L7.65893 0.227971C7.7174 0.089206 7.85383 0 8 0C8.14617 0 8.2826 0.089206 8.34107 0.227971L10.4265 5.14421L15.6692 5.6398C15.8154 5.64971 15.9421 5.75874 15.9811 5.8975C16.0298 6.03627 15.9811 6.19486 15.8739 6.29398L11.9272 9.83248L13.0868 15.056H13.0771Z" fill="#FFE600"/>
                          </svg>
                      {% endfor %}
                    </div>
                    <span style="color:{{ block.settings.title_color }};">{{ block.settings.star_text }}</span>
                  </div>
                  {% endif %}
                  {% if block.settings.sub_text != blank %}
                    <span class="sub_text" style="color: {{ block.settings.title_color }};">{{ block.settings.sub_text }}</span>
                   {% endif %} 
                  {% if block.settings.tite != blank %}
                    <h2 class="home-banner-title px-3 px-md-0 heading_txt text-capitalize" style="color: {{ block.settings.title_color }};" >
                      {{ block.settings.tite }}
                    </h2>
                  {% endif %}
                  {% if block.settings.second_sub_text != blank %}
                    <span class="second_sub_text" style="color: {{ block.settings.title_color }};">{{ block.settings.second_sub_text }}</span>
                   {% endif %} 
                  {% if block.settings.sub_title != blank %}
                    <a href="{{ block.settings.url }}">
                    <div class="h6 px-4 px-md-0 text-uppercase sub_heading_txt">
                      {{ block.settings.sub_title }}
                    </div>
                    </a>   
                  {% endif %}
                   {% comment %}
                  {% if block.settings.desc != blank %}
                    <p class="px-4 px-md-0 fs-lg caption_txt mb-5" style="color: {{ section.settings.content_color }};">
                      {{ block.settings.desc }}
                    </p>
                  {% endif %}
                 {% endcomment %}


                 {% if  block.settings.enable_timer != blank or  block.settings.end_date != blank %}
                    <div id="black-friday-timer" class="black-friday-timer" data-end-date="{{ block.settings.end_date }}"{% if block.settings.show_timer == true %}style="display:block;"{% else %}style="display:none;"{% endif %}>
                      <div class="bf-container">
                        <h2 class="bf-title">{{ block.settings.heading }}</h2>

                        <div class="bf-timer">
                          <div class="bf-unit">
                            <span class="bf-number" id="days">00</span>
                            <span class="bf-label">day</span>
                          </div>

                          <div class="bf-unit">
                            <span class="bf-number" id="hours">00</span>
                            <span class="bf-label">hr</span>
                          </div>

                          <div class="bf-unit">
                            <span class="bf-number" id="minutes">00</span>
                            <span class="bf-label">min</span>
                          </div>

                          <div class="bf-unit">
                            <span class="bf-number" id="seconds">00</span>
                            <span class="bf-label">sec</span>
                          </div>
                        </div>
                      </div>
                    </div>
                  {% endif %}


                  {% if block.settings.btn_url != blank or block.settings.button != blank %}
                  <div class="banner_btn_wrp">
                    <a href="{{ block.settings.btn_url }}" class="button  mb-2 mb-lg-0" {% if block.settings.link_open == true %}target="_blank"{% endif %}>
                      {{- block.settings.button -}}
                    </a>
                  </div> 
                  {% endif %}

                  {% if block.settings.bottom_text != blank %}
                    <div class="btn_bottom_text">
                      {{ block.settings.bottom_text }}
                    </div>
                  {% endif %}
                     <div class="klaviyo-form-YrJUZU" {% if block.settings.email == true %}style="display:block;"{% else %}style="display:none;"{% endif %}></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="swiper-pagination"></div>

    <div class="swiper-button-next hero-button-next dr-icon-chevron-right text-white border-white"></div>
    <div class="swiper-button-prev hero-button-prev dr-icon-chevron-right text-white border-white"></div>
  </div>
</section>
<script>
document.addEventListener("DOMContentLoaded", function () {
  const timerSection = document.getElementById('black-friday-timer');
  if (!timerSection) return;

  const endDateRaw = timerSection.dataset.endDate || '';

  // --- FIX FOR iOS SAFARI DATE PARSING ---
  function parseDateForIOS(dateStr) {
    // Supports formats like: "2025-11-20", "2025-11-20 23:59"
    const parts = dateStr.split(/[- :T]/);

    return new Date(
      parts[0],         
      parts[1] - 1,     
      parts[2],         
      parts[3] || 0,    
      parts[4] || 0,    
      parts[5] || 0     
    );
  }

  const endDate = parseDateForIOS(endDateRaw);

  const endDateToronto = new Date(
    endDate.toLocaleString("en-US", { timeZone: "America/Toronto" })
  ).getTime();

  // elements
  const daysEl = document.getElementById('days');
  const hoursEl = document.getElementById('hours');
  const minsEl = document.getElementById('minutes');
  const secsEl = document.getElementById('seconds');

  function setIfChanged(el, value) {
    if (el && el.textContent !== value) {
      el.textContent = value;
    }
  }

  function tick() {
    const nowToronto = new Date(
      new Date().toLocaleString("en-US", { timeZone: "America/Toronto" })
    ).getTime();

    if (isNaN(endDateToronto)) {
      timerSection.style.display = 'none';
      clearInterval(intervalId);
      return;
    }

    const distance = endDateToronto - nowToronto;

    if (distance <= 0) {
      timerSection.style.display = 'none';
      clearInterval(intervalId);
      return;
    }

    const days = Math.floor(distance / (1000 * 60 * 60 * 24));
    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((distance % (1000 * 60)) / 1000);

    setIfChanged(daysEl, String(days).padStart(2, '0'));
    setIfChanged(hoursEl, String(hours).padStart(2, '0'));
    setIfChanged(minsEl, String(minutes).padStart(2, '0'));
    setIfChanged(secsEl, String(seconds).padStart(2, '0'));
  }

  tick();
  const intervalId = setInterval(tick, 1000);
});
</script>
<script>
   var swiper = new Swiper('.header-slider-desktop', {
   slidesPerView: 1,
   {% comment %} autoplay: {
    delay: 5000,
  }, {% endcomment %}
  pagination: {
    el: '.swiper-pagination',
    clickable: true
  },
  navigation: {
    nextEl: '.swiper-button-next',
    prevEl: '.swiper-button-prev',
  }
     });
</script>

{% schema %}
{
  "name": "Home Banner",
  "class": "header-slider",
  "settings": [
    {
      "type": "checkbox",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": true
    },
    {
      "type": "color",
      "id": "content_color",
      "label": "Content Text Color",
      "default": "#fff"
    }
  ],
  "blocks": [

    {
      "type": "text",
      "name": "block",
      "settings":[
        {
          "type": "color",
          "id": "bg_color",
          "label": "Bg Color",
           "default": "#fff"
        },
        {
          "type": "text",
          "id": "custom_class",
          "label": "Custom Class"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image"
        },
           {
          "type": "image_picker",
          "id": "image1",
          "label": "Mob Image"
        },
        {
          "type": "text",
          "id": "star_text",
          "label": "Star Text"
        },
        {
          "type": "html",
          "id": "sub_text",
          "label": "Sub Text"
        },
        {
          "type": "html",
          "id": "tite",
          "label": "Title"
        },
        {
          "type": "html",
          "id": "second_sub_text",
          "label": "Secon sub text"
        },
        {
          "type": "color",
          "id": "title_color",
          "label": "Title Color",
          "default": "#fff"
        },
        {
          "type": "text",
          "id": "sub_title",
          "label": "Sub Title"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "button",
          "label": "Button Title"
        },
        {
          "type": "url",
          "id": "btn_url",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "link_open",
          "label": "Link Open New Windows",
          "default": false
        },
        {
          "type": "text",
          "id": "bottom_text",
          "label": "Bottom Text"
        },
        {
  "type": "checkbox",
  "id": "show_timer",
  "label": "Show Black Friday Timer",
  "default": true
},
         {
      "type": "checkbox",
      "id": "enable_timer",
      "label": "Enable Timer",
      "default": true
    },
    
    {
      "type": "text",
      "id": "heading",
      "label": "Timer Heading",
      "default": "Black Friday is Live!"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "End Date (YYYY-MM-DD HH:MM:SS)",
      "default": "2025-11-30 00:00:00"
    },
         {
  "type": "checkbox",
  "id": "email",
  "label": "Black Friday Email",
  "default": true
},
      ]
    },
  ],
  "presets": [
    {
      "name": "Home Banner"
    }
  ]
}
{% endschema %}
