{%- liquid
  assign global_start = section.settings.global_start | default: '2026-01-01T00:00:00Z'
  assign global_end   = section.settings.global_end   | default: '2030-01-01T00:00:00Z'
-%}

<script>
(function () {
  'use strict';

  const CONFIG = {

    globalStart : "{{ global_start | escape }}",
    globalEnd   : "{{ global_end   | escape }}",

    theme: {
      cartDrawerSection  : "{{ section.settings.cart_drawer_section  | default: 'cart-drawer'       | escape }}",
      cartIconSection    : "{{ section.settings.cart_icon_section    | default: 'cart-icon-bubble'  | escape }}",
      cartDrawerId       : "{{ section.settings.cart_drawer_id       | default: 'CartDrawer'        | escape }}",
      cartDrawerInner    : "{{ section.settings.cart_drawer_inner    | default: '.drawer__inner'    | escape }}",
      cartIconBubbleId   : "{{ section.settings.cart_icon_bubble_id  | default: 'cart-icon-bubble'  | escape }}",
      cartCountSelectors : "{{ section.settings.cart_count_selectors | default: '.cart-count-bubble,[data-cart-count],.cart__count' | escape }}",
      loaderColor        : "{{ section.settings.loader_color         | default: '#c5003e'           | escape }}",
    },

    groups: [

      {%- for n in (1..10) -%}

        {%- assign k_active    = 'g' | append: n | append: '_active'    -%}
        {%- assign k_name      = 'g' | append: n | append: '_name'      -%}
        {%- assign k_start     = 'g' | append: n | append: '_start'     -%}
        {%- assign k_end       = 'g' | append: n | append: '_end'       -%}

        {%- assign k_trig1     = 'g' | append: n | append: '_trig1'     -%}
        {%- assign k_trig1_vid = 'g' | append: n | append: '_trig1_vid' -%}
        {%- assign k_trig2     = 'g' | append: n | append: '_trig2'     -%}
        {%- assign k_trig2_vid = 'g' | append: n | append: '_trig2_vid' -%}

        {%- assign k_gift1     = 'g' | append: n | append: '_gift1'     -%}
        {%- assign k_gift1_vid = 'g' | append: n | append: '_gift1_vid' -%}
        {%- assign k_gift1_qty = 'g' | append: n | append: '_gift1_qty' -%}
        {%- assign k_gift2     = 'g' | append: n | append: '_gift2'     -%}
        {%- assign k_gift2_vid = 'g' | append: n | append: '_gift2_vid' -%}
        {%- assign k_gift2_qty = 'g' | append: n | append: '_gift2_qty' -%}
        {%- assign k_gift3     = 'g' | append: n | append: '_gift3'     -%}
        {%- assign k_gift3_vid = 'g' | append: n | append: '_gift3_vid' -%}
        {%- assign k_gift3_qty = 'g' | append: n | append: '_gift3_qty' -%}

        {%- assign trig1_override = section.settings[k_trig1_vid] | strip -%}
        {%- if trig1_override != blank -%}
          {%- assign trig1_vid = trig1_override | times: 1 -%}
        {%- elsif section.settings[k_trig1] != blank -%}
          {%- assign trig1_vid = section.settings[k_trig1].variants.first.id -%}
        {%- else -%}
          {%- assign trig1_vid = nil -%}
        {%- endif -%}

        {%- assign trig2_override = section.settings[k_trig2_vid] | strip -%}
        {%- if trig2_override != blank -%}
          {%- assign trig2_vid = trig2_override | times: 1 -%}
        {%- elsif section.settings[k_trig2] != blank -%}
          {%- assign trig2_vid = section.settings[k_trig2].variants.first.id -%}
        {%- else -%}
          {%- assign trig2_vid = nil -%}
        {%- endif -%}

        {%- assign gift1_override = section.settings[k_gift1_vid] | strip -%}
        {%- if gift1_override != blank -%}
          {%- assign gift1_vid = gift1_override | times: 1 -%}
        {%- elsif section.settings[k_gift1] != blank -%}
          {%- assign gift1_vid = section.settings[k_gift1].variants.first.id -%}
        {%- else -%}
          {%- assign gift1_vid = nil -%}
        {%- endif -%}

        {%- assign gift2_override = section.settings[k_gift2_vid] | strip -%}
        {%- if gift2_override != blank -%}
          {%- assign gift2_vid = gift2_override | times: 1 -%}
        {%- elsif section.settings[k_gift2] != blank -%}
          {%- assign gift2_vid = section.settings[k_gift2].variants.first.id -%}
        {%- else -%}
          {%- assign gift2_vid = nil -%}
        {%- endif -%}

        {%- assign gift3_override = section.settings[k_gift3_vid] | strip -%}
        {%- if gift3_override != blank -%}
          {%- assign gift3_vid = gift3_override | times: 1 -%}
        {%- elsif section.settings[k_gift3] != blank -%}
          {%- assign gift3_vid = section.settings[k_gift3].variants.first.id -%}
        {%- else -%}
          {%- assign gift3_vid = nil -%}
        {%- endif -%}

        {%- if trig1_vid != nil and gift1_vid != nil -%}
        {
          id     : "g{{ n }}",
          name   : {{ section.settings[k_name] | default: '' | json }},
          active : {{ section.settings[k_active] | default: false }},

          startDate : {%- if section.settings[k_start] != blank -%}
                        {{ section.settings[k_start] | json }}
                      {%- else -%}null{%- endif -%},

          endDate   : {%- if section.settings[k_end] != blank -%}
                        {{ section.settings[k_end] | json }}
                      {%- else -%}null{%- endif -%},

          triggers: [
            {{ trig1_vid }}
            {%- if trig2_vid != nil -%}, {{ trig2_vid }}{%- endif -%}
          ],

          gifts: [
            {%- if gift1_vid != nil -%}
              { variantId: {{ gift1_vid }}, qty: {{ section.settings[k_gift1_qty] | default: 1 | times: 1 }} },
            {%- endif -%}
            {%- if gift2_vid != nil -%}
              { variantId: {{ gift2_vid }}, qty: {{ section.settings[k_gift2_qty] | default: 1 | times: 1 }} },
            {%- endif -%}
            {%- if gift3_vid != nil -%}
              { variantId: {{ gift3_vid }}, qty: {{ section.settings[k_gift3_qty] | default: 1 | times: 1 }} },
            {%- endif -%}
          ],
        },
        {%- endif -%}

      {%- endfor -%}

    ],

  };

  const TH = CONFIG.theme;

  function isGroupActive(g) {
    if (!g.active || !g.triggers.length || !g.gifts.length) return false;
    const now = Date.now();
    return now >= new Date(g.startDate || CONFIG.globalStart).getTime() &&
           now <= new Date(g.endDate   || CONFIG.globalEnd  ).getTime();
  }

  function gpk(id) { return '_fg_' + id; }

  function isGiftOf(item, groupId) {
    return item.properties && item.properties[gpk(groupId)] === 'true';
  }

  function hasAnyGiftProp(item) {
    if (!item.properties) return false;
    return Object.keys(item.properties).some(k => k.startsWith('_fg_'));
  }

  let _int = false;
  const _f  = window.fetch;

  window.fetch = function (...a) {
    return _f.apply(this, a).then(res => {
      if (!_int && /\/cart\/(add|change|update)(\.js)?/.test((a[0] || '').toString())) {
        triggerSync(200);
      }
      return res;
    });
  };

  function iFetch(url, opt) {
    _int = true;
    return _f(url, opt).finally(() => { _int = false; });
  }

  (function () {
    const oo = XMLHttpRequest.prototype.open;
    const os = XMLHttpRequest.prototype.send;
    XMLHttpRequest.prototype.open = function (m, u, ...r) {
      this._fu = u || '';
      return oo.apply(this, [m, u, ...r]);
    };
    XMLHttpRequest.prototype.send = function (...a) {
      this.addEventListener('load', () => {
        if (!_int && /\/cart\/(add|change|update)(\.js)?/.test(this._fu)) triggerSync(200);
      });
      return os.apply(this, a);
    };
  })();

  const getCart   = () => _f('/cart.js', { headers: { Accept: 'application/json' } }).then(r => r.json());
  const cartAdd   = items => iFetch('/cart/add.js',    { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ items }) });
  const cartChg   = (key, qty) => iFetch('/cart/change.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: key, quantity: qty }) });

  function showLoader() {
    const d = document.getElementById(TH.cartDrawerId);
    if (!d) return;
    let l = d.querySelector('.fg-loader');
    if (!l) {
      l = document.createElement('div');
      l.className = 'fg-loader';
      l.innerHTML = '<div style="position:absolute;top:0;left:0;width:100%;height:100%;' +
        'background:rgba(255,255,255,.88);z-index:9999;display:flex;align-items:center;justify-content:center;">' +
        '<div style="width:36px;height:36px;border:3px solid #eee;border-top-color:' +
        TH.loaderColor + ';border-radius:50%;animation:fgSpin .7s linear infinite;"></div></div>' +
        '<style>@keyframes fgSpin{to{transform:rotate(360deg)}}</style>';
      d.style.position = 'relative';
      d.appendChild(l);
    }
    l.style.display = '';
  }

  function hideLoader() {
    const l = document.querySelector('#' + TH.cartDrawerId + ' .fg-loader');
    if (l) l.style.display = 'none';
  }

  async function refreshCartUI() {
    try {
      const [sRes, cRes] = await Promise.all([
        _f('/?sections=' + TH.cartDrawerSection + ',' + TH.cartIconSection),
        _f('/cart.js'),
      ]);
      const cart = await cRes.json();
      const sec  = sRes.ok ? await sRes.json() : null;

      if (sec && sec[TH.cartDrawerSection]) {
        const tmp = document.createElement('div');
        tmp.innerHTML = sec[TH.cartDrawerSection];
        const el = document.getElementById(TH.cartDrawerId);
        if (el) {
          const ldr    = el.querySelector('.fg-loader');
          const oldInr = el.querySelector(TH.cartDrawerInner);
          const newInr = tmp.querySelector(TH.cartDrawerInner);
          if (oldInr && newInr) oldInr.innerHTML = newInr.innerHTML;
          else if (newInr) el.innerHTML = newInr.outerHTML;
          if (ldr) el.appendChild(ldr);
          el.classList.toggle('is-empty', cart.item_count === 0);
        }
      }

      if (sec && sec[TH.cartIconSection]) {
        const ic = document.getElementById(TH.cartIconBubbleId);
        if (ic) {
          const tmp = document.createElement('div');
          tmp.innerHTML = sec[TH.cartIconSection];
          const ni = tmp.querySelector('#' + TH.cartIconBubbleId);
          if (ni) ic.innerHTML = ni.innerHTML;
        }
      }

      document.querySelectorAll(TH.cartCountSelectors).forEach(el => {
        el.textContent = cart.item_count;
        el.classList.toggle('hidden', cart.item_count === 0);
      });

      ['cart:refresh','cart:updated'].forEach(ev =>
        document.dispatchEvent(new CustomEvent(ev, { detail: { cart }, bubbles: true }))
      );

      const cd = document.querySelector('cart-drawer');
      if (cd) {
        cd.classList.toggle('is-empty', cart.item_count === 0);
        if (typeof cd.renderContents === 'function') cd.renderContents({ detail: { cart } });
      }

      sortCartDrawer(cart);

    } catch (e) { console.error('[FG PRO] UI refresh:', e); }
    hideLoader();
  }

  // ─── SORT: gift/properties items always on TOP, normal items below ───────────
  function sortCartDrawer(cart) {
    const drawer = document.getElementById(TH.cartDrawerId);
    if (!drawer) return;

    // Build a map: key/index → priority
    // priority 0 = has gift properties (TOP)
    // priority 1 = normal item (BOTTOM)
    const pmap = {};

    cart.items.forEach((item, idx) => {
      // An item is a "gift" row if it has any _fg_* property key
      const isGift = hasAnyGiftProp(item);
      const priority = isGift ? 0 : 1;
      pmap[item.key]   = priority;
      pmap[idx + 1]    = priority;   // 1-based line index fallback
    });

    function getPriority(el) {
      const key = el.getAttribute('key') || el.dataset.key || '';
      if (pmap[key] !== undefined) return pmap[key];

      const idx = parseInt(el.dataset.index || el.dataset.line || el.dataset.lineIndex || '');
      if (!isNaN(idx) && pmap[idx] !== undefined) return pmap[idx];

      const child = el.querySelector('[key],[data-key],[data-index],[data-line]');
      if (child) {
        const ck = child.getAttribute('key') || child.dataset.key || '';
        if (pmap[ck] !== undefined) return pmap[ck];
        const ci = parseInt(child.dataset.index || child.dataset.line || '');
        if (!isNaN(ci) && pmap[ci] !== undefined) return pmap[ci];
      }

      return 9999;
    }

    const parentSelectors = [
      'tbody',
      '.cart-items',
      '.cart__items',
      '[data-cart-items]',
      '.cart-drawer__contents',
      '.drawer__contents',
    ];

    for (const sel of parentSelectors) {
      const parent = drawer.querySelector(sel);
      if (!parent) continue;

      const rows = Array.from(parent.children).filter(el =>
        !['THEAD', 'TFOOT', 'SCRIPT', 'STYLE'].includes(el.tagName)
      );
      if (rows.length < 2) continue;

      // Stable sort: gifts first (priority 0), then normal (priority 1)
      const sorted = [...rows].sort((a, b) => getPriority(a) - getPriority(b));

      if (sorted.some((el, i) => el !== rows[i])) {
        sorted.forEach(el => parent.appendChild(el));
      }
      break; // only sort the first matching container
    }
  }

  // ─── FULL REBUILD STRATEGY ───────────────────────────────────────────────────
  // Every sync does: compute needed gifts → remove ALL gift lines → re-add
  // merged as single lines per (groupId+variantId).
  //
  // WHY: Shopify applies discount codes top-down. Gift lines must sit at the TOP
  // so the 100% discount hits them first. Any qty-change (cartChg) on existing
  // lines doesn't reorder them. Only removing + re-adding guarantees they land
  // at the top of the Shopify cart array.
  //
  // Result order in cart.js:
  //   [gift line(s) — freshly added, qty=correct, merged]
  //   [normal product lines — untouched, stay in original position below]

  function computeNeededGifts(cart) {
    // Returns array of { variantId, qty, groupId } for active groups
    const vm = {};
    cart.items.forEach(item => {
      (vm[item.variant_id] = vm[item.variant_id] || []).push(item);
    });

    const needed = [];
    for (const g of CONFIG.groups) {
      if (!isGroupActive(g)) continue;
      const triggerQty = g.triggers.reduce(
        (s, vid) => s + (vm[vid] || []).filter(i => !isGiftOf(i, g.id)).reduce((ss, i) => ss + i.quantity, 0),
        0
      );
      if (triggerQty === 0) continue;
      for (const { variantId, qty } of g.gifts) {
        needed.push({ variantId, qty: triggerQty * qty, groupId: g.id });
      }
    }
    return needed;
  }

  function giftsAreCorrect(cart, needed) {
    // Check 1: every needed gift exists as exactly ONE line with exact qty
    for (const { variantId, qty, groupId } of needed) {
      const lines = cart.items.filter(i => i.variant_id === variantId && isGiftOf(i, groupId));
      if (lines.length !== 1 || lines[0].quantity !== qty) return false;
    }
    // Check 2: no stale gift lines for inactive groups
    for (const g of CONFIG.groups) {
      if (isGroupActive(g)) continue;
      if (cart.items.some(i => isGiftOf(i, g.id))) return false;
    }
    // Check 3: all gift lines appear BEFORE all normal lines
    const firstNormalIdx = cart.items.findIndex(i => !hasAnyGiftProp(i));
    const lastGiftIdx    = cart.items.reduce((last, i, idx) => hasAnyGiftProp(i) ? idx : last, -1);
    if (firstNormalIdx !== -1 && lastGiftIdx > firstNormalIdx) return false;

    return true;
  }

  async function fullRebuildGifts(cart, needed) {
    // ── 1. Remove ALL existing gift lines ─────────────────────────────────────
    const allGiftLines = cart.items.filter(i => hasAnyGiftProp(i));
    for (const item of allGiftLines) {
      await cartChg(item.key, 0);
    }
    // Also remove stale lines for inactive groups (if any slipped through)
    for (const g of CONFIG.groups) {
      if (isGroupActive(g)) continue;
      const stale = cart.items.filter(i => isGiftOf(i, g.id) && !allGiftLines.includes(i));
      for (const item of stale) await cartChg(item.key, 0);
    }

    if (needed.length === 0) return; // nothing to add back

    // ── 2. Pause so Shopify settles the deletions ─────────────────────────────
    await new Promise(r => setTimeout(r, 300));

    // ── 3. Add gift lines ONE BY ONE sequentially ─────────────────────────────
    // WHY sequential and not batch:
    // Shopify applies discount codes to lines in the order they were added.
    // Batch add (/cart/add with multiple items) = Shopify processes together,
    // discount may attach to ANY line in the batch — often the wrong one.
    //
    // Sequential adds = each gift gets its own position timestamp in Shopify.
    // Gifts added FIRST → sit at TOP of cart array → discount hits gifts first
    // → 100% off on gifts, paid products untouched. ✓
    for (const { variantId, qty, groupId } of needed) {
      await cartAdd([{
        id         : variantId,
        quantity   : qty,
        properties : {
          _isFreeGift    : 'true',
          [gpk(groupId)] : 'true',
          _source        : 'free_gift_promo',
        },
      }]);
      // Small gap between each add so Shopify registers separate positions
      if (needed.length > 1) await new Promise(r => setTimeout(r, 150));
    }
  }

  let _sync = false, _pending = false, _t = null;

  async function syncFreeGifts() {
    if (_sync) return;
    _sync = true;
    _pending = false;
    showLoader();

    try {
      const cart   = await getCart();
      const needed = computeNeededGifts(cart);

      if (giftsAreCorrect(cart, needed)) {
        // Everything is already perfect — just ensure DOM sort is right
        sortCartDrawer(cart);
        hideLoader();
      } else {
        // Full remove → re-add cycle (loader stays on throughout)
        await fullRebuildGifts(cart, needed);
        await new Promise(r => setTimeout(r, 200));
        await refreshCartUI();
      }

    } catch (e) { console.error('[FG PRO] Sync:', e); hideLoader(); }

    _sync = false;
    if (_pending) triggerSync(300);
  }

  function triggerSync(ms) {
    if (_sync) { _pending = true; return; }
    clearTimeout(_t);
    _t = setTimeout(syncFreeGifts, ms || 300);
  }

  document.addEventListener('submit', e => {
    if (e.target.matches('form[action*="/cart/add"]')) triggerSync(200);
  });

  document.addEventListener('click', e => {
    const t = e.target;
    if (t.closest('[name="plus"],[name="minus"],.quantity__button,.js-qty__adjust,[data-quantity-plus],[data-quantity-minus],[data-cart-drawer-toggle],[data-cart-toggle],.cart-link,[href="/cart"]')) {
      triggerSync(350);
    }
  });

  document.addEventListener('change', e => {
    if (e.target.matches('.quantity__input,[data-quantity-input],input[type="number"]')) triggerSync(350);
  });

  document.readyState === 'loading'
    ? document.addEventListener('DOMContentLoaded', () => triggerSync(600))
    : triggerSync(600);

  window.addEventListener('pageshow', e => { if (e.persisted) triggerSync(600); });

  window.freeGiftProSync = () => triggerSync(100);

})();
</script>

{% schema %}
{
  "name": "Free Gift Pro",
  "settings": [

    {
      "type": "header",
      "content": "⏰ Global Time Window"
    },
    {
      "type": "paragraph",
      "content": "All groups are off outside this window. Use ISO 8601 format: 2026-04-07T04:30:00Z"
    },
    {
      "type": "text",
      "id": "global_start",
      "label": "Global Start Date",
      "default": "2026-04-07T04:30:00Z",
      "placeholder": "2026-04-07T04:30:00Z"
    },
    {
      "type": "text",
      "id": "global_end",
      "label": "Global End Date",
      "default": "2029-05-07T04:59:59Z",
      "placeholder": "2029-05-07T04:59:59Z"
    },

    {
      "type": "header",
      "content": "🎨 Theme Settings"
    },
    {
      "type": "paragraph",
      "content": "Match these to your theme's cart drawer code. Check browser DevTools if unsure."
    },
    {
      "type": "text",
      "id": "cart_drawer_section",
      "label": "Cart Drawer Section File Name",
      "default": "cart-drawer",
      "info": "File name inside /sections/ without .liquid — e.g. cart-drawer"
    },
    {
      "type": "text",
      "id": "cart_icon_section",
      "label": "Cart Icon Bubble Section Name",
      "default": "cart-icon-bubble"
    },
    {
      "type": "text",
      "id": "cart_drawer_id",
      "label": "Cart Drawer Element ID",
      "default": "CartDrawer",
      "info": "The id=\"...\" on your cart drawer container"
    },
    {
      "type": "text",
      "id": "cart_drawer_inner",
      "label": "Cart Drawer Inner Selector (CSS)",
      "default": ".drawer__inner",
      "info": "CSS selector for the inner scrollable area"
    },
    {
      "type": "text",
      "id": "cart_icon_bubble_id",
      "label": "Cart Icon Bubble ID",
      "default": "cart-icon-bubble"
    },
    {
      "type": "text",
      "id": "cart_count_selectors",
      "label": "Cart Count Badge Selectors (CSS, comma-separated)",
      "default": ".cart-count-bubble,[data-cart-count],.cart__count",
      "info": "All elements showing cart item count"
    },
    {
      "type": "color",
      "id": "loader_color",
      "label": "Loader Spinner Colour",
      "default": "#c5003e"
    },

    {
      "type": "header",
      "content": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    },
    {
      "type": "header",
      "content": "🎁 Group 1"
    },
    {
      "type": "checkbox",
      "id": "g1_active",
      "label": "Enable Group 1",
      "default": false
    },
    {
      "type": "text",
      "id": "g1_name",
      "label": "Group 1 — Internal Name",
      "placeholder": "e.g. SuperStar Pimple Patches Bundle"
    },
    {
      "type": "text",
      "id": "g1_start",
      "label": "Group 1 — Start Date Override",
      "placeholder": "Leave blank to use Global Start",
      "info": "ISO 8601 format. Leave blank = use Global Start"
    },
    {
      "type": "text",
      "id": "g1_end",
      "label": "Group 1 — End Date Override",
      "placeholder": "Leave blank to use Global End"
    },
    {
      "type": "product",
      "id": "g1_trig1",
      "label": "Group 1 — Trigger Product 1"
    },
    {
      "type": "text",
      "id": "g1_trig1_vid",
      "label": "Group 1 — Trigger 1 Specific Variant ID",
      "placeholder": "Leave blank = uses first variant",
      "info": "Only needed if the product has multiple variants"
    },
    {
      "type": "product",
      "id": "g1_trig2",
      "label": "Group 1 — Trigger Product 2 (optional)"
    },
    {
      "type": "text",
      "id": "g1_trig2_vid",
      "label": "Group 1 — Trigger 2 Specific Variant ID",
      "placeholder": "Leave blank = uses first variant"
    },
    {
      "type": "product",
      "id": "g1_gift1",
      "label": "Group 1 — Free Gift 1"
    },
    {
      "type": "text",
      "id": "g1_gift1_vid",
      "label": "Group 1 — Gift 1 Specific Variant ID",
      "placeholder": "Leave blank = uses first variant"
    },
    {
      "type": "number",
      "id": "g1_gift1_qty",
      "label": "Group 1 — Gift 1 Qty per trigger unit",
      "default": 1,
      "info": "Buy 1 trigger = get this many free. Buy 2 = double this."
