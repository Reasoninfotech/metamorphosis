{% if product.handle == 'skinexcellence-exosome-serum'
  or product.handle == 'rubyradiance-rejuvenator'
  or product.handle == 'new-rubyradiance-rejuvenator'
%}
  {% style %}
    .pioneering-section .pioneering_img_wrp{position: relative;}

    .pioneering-section .pioneering_img_wrp .banner_text_block{position: absolute;top: 0;left: 78px;max-width: 624px;width: 100%;height: 100%;display: flex;flex-direction: column;gap: 10px;justify-content: space-between;padding: 80px 15px;}

    .pioneering-section .pioneering_img_wrp .pioneering_img{}

    .pioneering-section .pioneering_img .mobile_img{display:none;}

    .pioneering-section .pioneering_img img{width:100%;vertical-align: middle; max-height: 620px; object-fit: cover;}

    .pioneering-section .banner_title{text-align: center;}
    .pioneering-section .banner_title .main_title{text-transform: uppercase;}
    .pioneering-section .banner_title span{color:#000;}

    .pioneering-section .banner_des{max-width: 475px;margin: 0 auto;text-align: center;}
    .pioneering-section .banner_des p{margin: 0;line-height: normal;font-size: 20px;color: #000;}

    .pioneering-section .banner_btn_wrp{text-align:center;}
    .pioneering-section .banner_btn_wrp .common_btn{min-width: 280px;}


    @media screen and (max-width: 1439px){
      .pioneering-section .pioneering_img_wrp .banner_text_block{max-width:500px;}
    }

    @media screen and (max-width: 1199px){
      .pioneering-section .pioneering_img_wrp .banner_text_block{padding: 50px 15px;}
    }

    @media screen and (max-width: 991px){
      .pioneering-section .pioneering_img .desktop_img{display:none;}
      .pioneering-section .pioneering_img .mobile_img{display:block;}

      .pioneering-section .pioneering_img_wrp{display: flex;flex-direction: column-reverse;background-image: url(https://cdn.shopify.com/s/files/1/0693/9849/5445/files/image_33dgdfg43_1_2.jpg?v=1751284277);background-size: cover;}
      .pioneering-section .pioneering_img_wrp .banner_text_block{position: unset;max-width: 100%;gap: 32px;}
    }
  {% endstyle %}

  <div class="pioneering-section">
    <div class="pioneering_img_wrp">
      <div class="pioneering_img">
        {% if section.settings.img != blank %}
          <img
            src="{{ section.settings.img | image_url: width: 1920 }}"
            {% if section.settings.mobile_img != blank %}
              class="desktop_img"
            {% endif %}
            fetchpriority="high"
            width="{{ section.settings.img.width }}"
            height="{{ section.settings.img.height }}"
            alt="{{ section.settings.img.alt | escape }}"
          >
        {% endif %}
        {% if section.settings.mobile_img != blank %}
          <img src="{{ section.settings.mobile_img | img_url : "master" }}" class="mobile_img" loading="lazy">
        {% endif %}
      </div>
      <div class="banner_text_block">
        <div class="banner_title">
          {% if section.settings.text != blank %}
            <h2 class="main_title">{{ section.settings.text }}</h2>
          {% endif %}
          {% if section.settings.sub_text != blank %}
            <span>{{ section.settings.sub_text }}</span>
          {% endif %}
        </div>
        {% if section.settings.content != blank %}
          <div class="banner_des">
            {{ section.settings.content }}
          </div>
        {% endif %}
        <div class="banner_btn_wrp">
          {% if section.settings.btn_url != blank %}
            <a href="{{ section.settings.btn_url }}" class="common_btn">{{ section.settings.btn_text }}</a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Pioneering Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "img",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_img",
      "label": "Mobile Image"
    },
    {
      "type": "html",
      "id": "text",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "sub_text",
      "label": "Sub text"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Pioneering Section"
    }
  ]
}
{% endschema %}
