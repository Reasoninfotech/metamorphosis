{{ 'image-text-btn-section.css' | asset_url | stylesheet_tag }}
<section
  class="img_text_block pb_90"
  id="icon-with-text-{{ section.id }}"
  style="background:{{ section.settings.bg_color }}"
>
  <div class="page-width">
    <div class="img_text-main" style="background:{{ section.settings.text_block }}">
      {% if section.settings.img != blank %}
        <div class="img_block-wrp">
          <figure>
            <img src="{{ section.settings.img | img_url:"master" }}" loading="lazy">
          </figure>
        </div>
      {% endif %}

      <div class="img_text-main-content">
        <div class="img_text-main-content-inner">
          {% if section.settings.heading != blank %}
            <h2 class="main_title">{{ section.settings.heading }}</h2>
          {% endif %}
          {% if section.settings.content != blank %}
            <div class="text">{{ section.settings.content }}</div>
          {% endif %}
          {% if section.settings.btn != blank and section.settings.url != blank %}
            <div class="img-text-btn-wrp">
              <a href="{{ section.settings.url }}" class="common_btn">{{ section.settings.btn }}</a>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image Text",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color"
    },
    {
      "type": "color",
      "id": "text_block",
      "label": "Text Block Background Color",
      "default": "#FAFAFA"
    },
    {
      "type": "image_picker",
      "id": "img",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    },
    {
      "type": "text",
      "id": "btn",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Url to Navigate"
    }
  ],
  "presets": [
    {
      "name": "Image Text"
    }
  ]
}
{% endschema %}
