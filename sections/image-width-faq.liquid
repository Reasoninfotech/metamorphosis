  $(document).ready(function(){
    $("#faqs-{{ section.id }} .faq_block_questions").click(function(){
        let parentBlock = $(this).closest('.faq_section_block_inner');
        let dataIndex = parentBlock.data('index');

        if (!parentBlock.hasClass('faq_block-active')) {
            $('.faq_section_block_inner').removeClass('faq_block-active');
            $('.faq_section_block_inner').find('.faq_answer').slideUp();
            $('.faq_section_block_inner').find('.faq_minus').addClass('hidden');
            $('.faq_section_block_inner').find('.faq_plus').removeClass('hidden');
            $(".faq_imag").removeClass('faq_block-active');

            parentBlock.addClass('faq_block-active');
            parentBlock.find('.faq_answer').slideDown();
            $(this).find('.faq_plus').addClass('hidden');
            $(this).find('.faq_minus').removeClass('hidden');

            $(".faq_imag[data-index='" + dataIndex + "']").addClass('faq_block-active');
        }
    });
});

  
  
</script>

{% schema %}
{
  "name": "Image with faq",
  "settings":[
    {
      "type": "text",
      "id": "sub-mission",
      "label": "Main Sub Text",
      "default": "Support is Our Mission"
    },
    {
      "type":"text",
      "id":"title",
      "label":"Main Title"
    },
    {
      "type": "select",
      "id": "containt_movie",
      "label": "position",
      "options": [
        {
          "value": "left-movie",
          "label": "Image left"
        },
        {
          "value": "right-movie",
          "label": "Image right"
        }
      ]
    },
    {
      "type":"text",
      "id":"custom_class",
      "label":"Custom Class"
    }
  ],
  "blocks":[
    {
      "name":"Faq",
      "type":"text",
      "settings":[
         {
          "type":"text",
          "id":"heading",
          "label":"Heading"
        },
        {
          "type":"richtext",
          "id":"description",
          "label":"Description"
        },
        {
          "type":"image_picker",
          "id":"image",
          "label":"Image"
        },
        {
          "type":"image_picker",
          "id":"mob_image",
          "label":"Mobile Image"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "product_img",
          "label": "Product Image"
        },
