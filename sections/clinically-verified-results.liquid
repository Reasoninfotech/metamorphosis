                      </g>
                      <defs>
                      <clipPath id="clip0_10904_34267">
                      <rect width="10" height="15" fill="white" transform="translate(10 15) rotate(-180)"/>
                      </clipPath>
                      </defs>
                    </svg>
                  </span>
                </button>

                <div
                  class="cvr-mob-tab__body {% if forloop.first %}open{% endif %}"
                  id="cvr-mob-body-{{ section_id }}-{{ forloop.index }}"
                >
                  <div class="cvr-mob-tab__content">
                    {% comment %}
                      {%- if section.settings.after_label != blank -%}
                        <p class="cvr-after-label">{{ section.settings.after_label }}</p>
                      {%- endif -%}
                    {% endcomment %}

                    <div class="cvr-mob-sliders">
                      <!-- Mobile Slider 1 -->
                      <div class="cvr-slider-col">
                        {%- if block.settings.after_label_1 != blank -%}
                          <p class="cvr-after-label">{{ block.settings.after_label_1 }}</p>
                        {%- endif -%}
                        <div class="cvr-compare" data-slider>
                          <div class="cvr-compare__layer cvr-compare__after">
                            {%- if block.settings.after_image_1 != blank -%}
                              <img
                                src="{{ block.settings.after_image_1 | image_url: width: 600 }}"
                                alt="{{ block.settings.after_image_1.alt | escape | default: 'After' }}"
                                loading="lazy"
                              >
                            {%- else -%}
                              <div
                                class="cvr-compare__placeholder"
                                style="background:linear-gradient(160deg,#f0e2d6,#d4b89a);"
                              ></div>
                            {%- endif -%}
                          </div>
                          <div class="cvr-compare__layer cvr-compare__before" data-before>
                            {%- if block.settings.before_image_1 != blank -%}
                              <img
                                src="{{ block.settings.before_image_1 | image_url: width: 600 }}"
                                alt="{{ block.settings.before_image_1.alt | escape | default: 'Before' }}"
                                loading="lazy"
                              >
                            {%- else -%}
                              <div
                                class="cvr-compare__placeholder"
                                style="background:linear-gradient(160deg,#c0907a,#96604a);"
