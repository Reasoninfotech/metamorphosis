    #cvr-{{ section_id }} .cvr-mob-tab__trigger.open{border-width:2px;border-color:#000;}
    #cvr-{{ section_id }} .cvr-mob-tab__trigger.open .cvr-mob-tab__label { color: var(--cvr-text); }
    #cvr-{{ section_id }} .cvr-mob-tab__trigger.open .cvr-mob-tab__icon  { transform: rotate(180deg); }
    #cvr-{{ section_id }} .cvr-after-label{
