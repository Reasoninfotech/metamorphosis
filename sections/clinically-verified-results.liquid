                            </svg>
                          </div>
                        </div>
                        {%- if block.settings.stat_2 != blank or block.settings.stat_desc_2 != blank -%}
                          <div class="cvr-stat">
                            <div class="cvr-stat__number">{{ block.settings.stat_2 }}%</div>
