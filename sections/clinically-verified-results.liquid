<style>
  /* ────────────────────────────────────────
     BASE RESET & VARIABLES
  ──────────────────────────────────────── */
  #cvr-{{ section_id }} *,
  #cvr-{{ section_id }} *::before,
  #cvr-{{ section_id }} *::after {
    box-sizing: border-box;
  }

  #cvr-{{ section_id }} {
    background-color: var(--cvr-bg, #f8f6f3);
    color: var(--cvr-text, #2c2420);
    padding-top: var(--cvr-pt, 80px);
    padding-bottom: var(--cvr-pb, 80px);
  }

  /* ────────────────────────────────────────
     CONTAINER
  ──────────────────────────────────────── */
  #cvr-{{ section_id }} .main-container{
    max-width: {{ section.settings.container_width }}px;
    margin-left: auto;
    margin-right: auto;
    padding-left: {{ section.settings.container_gutter }}px;
    padding-right: {{ section.settings.container_gutter }}px;
  }
  #cvr-{{ section_id }} .cvr-container {
  }

  /* ────────────────────────────────────────
     SHARED TYPOGRAPHY
  ──────────────────────────────────────── */
  #cvr-{{ section_id }} .cvr-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cvr-accent, #a07d57);
    margin-bottom: 18px;
  }

  #cvr-{{ section_id }} .cvr-heading {
    color: var(--cvr-text, #2c2420);
    margin: 0 0 20px;
    font-weight: 500;
    font-size: 40px;
    line-height: 48px;
    text-transform: uppercase;
  }

  #cvr-{{ section_id }} .cvr-desc {
    font-size: 18px;
    font-weight: 400;
    letter-spacing: normal;
    line-height: 22px;
    color:  var(--cvr-text);
    margin-bottom: 34px;
  }

  #cvr-{{ section_id }} .cvr-footnote {
    color: color-mix(in srgb, var(--cvr-text) 45%, transparent);
    margin-top: 16px;
    font-weight: 400;
    font-size: 12px;
    line-height: normal;
    font-family: var(--argentum);
  }

  #cvr-{{ section_id }} .cvr-after-label {
    font-family:var(--argentum);
    font-weight: 400;
    font-size: 14px;
    line-height: normal;
    text-transform: uppercase;
    margin: 0 0 16px;
    color: color-mix(in srgb, var(--cvr-text) 55%, transparent);
    letter-spacing: normal;
  }

  /* ────────────────────────────────────────
     DESKTOP LAYOUT
  ──────────────────────────────────────── */
  #cvr-{{ section_id }} .cvr-mobile  { display: none; }
  #cvr-{{ section_id }} .cvr-desktop { display: block; }


  #cvr-{{ section_id }} .cvr-desktop .cvr-container {
    display: grid;
    grid-template-columns: {{ section.settings.left_col_width }}px 1fr;
    gap: {{ section.settings.col_gap }}px;
    align-items: start;
  }

  #cvr-{{ section_id }} .cvr-left {
    position: sticky;
    top: 80px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  /* Desktop tabs */
  #cvr-{{ section_id }} .cvr-tabs {
    {% comment %} border-top: 1px solid color-mix(in srgb, var(--cvr-text) 18%, transparent); {% endcomment %}
     display: flex;
      flex-direction: column;
      gap: 10px;
  }

  #cvr-{{ section_id }} .cvr-tab-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 12px 0;
    background: none;
    border: none;
    border-bottom: 1px solid color-mix(in srgb, var(--cvr-text) 18%, transparent);
    cursor: pointer;
    text-align: left;
  }
  #cvr-{{ section_id }} .cvr-tab-btn.active {
    border-width: 2px;
    border-color: #000;
  }
  #cvr-{{ section_id }} .cvr-tab-btn__text {

    color: color-mix(in srgb, var(--cvr-text) 50%, transparent);
    transition: color 0.25s;
    font-weight: 400;
    font-size: 14px;
    line-height: normal;
    text-align: center;
    text-transform: uppercase;
    font-family: var(--argentum);
  }
  #cvr-{{ section_id }} .cvr-cta-btn {
        text-transform: uppercase;
  }

  #cvr-{{ section_id }} .cvr-tab-btn__arrow {
    width: 18px; height: 18px;
    display: flex; align-items: center; justify-content: center;
    opacity: 0;
    transition: opacity 0.25s;
    flex-shrink: 0;
  }

  #cvr-{{ section_id }} .cvr-tab-btn__arrow svg {
    width: 13px; height: 13px;
    stroke: #000;
  }

  #cvr-{{ section_id }} .cvr-tab-btn.active .cvr-tab-btn__text,
  #cvr-{{ section_id }} .cvr-tab-btn:hover  .cvr-tab-btn__text {
    color: var(--cvr-text);
  }

  #cvr-{{ section_id }} .cvr-tab-btn.active .cvr-tab-btn__arrow { opacity: 1; }

  /* Desktop panels */
  #cvr-{{ section_id }} .cvr-panel { display: none; }

  #cvr-{{ section_id }} .cvr-panel.active {
    display: block;
    animation: cvrFadeUp 0.4s ease;
  }

  @keyframes cvrFadeUp {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ────────────────────────────────────────
     SLIDERS GRID
  ──────────────────────────────────────── */
  #cvr-{{ section_id }} .cvr-sliders-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.slider_gap }}px;
  }

  /* ────────────────────────────────────────
     COMPARE WIDGET
  ──────────────────────────────────────── */
  #cvr-{{ section_id }} .cvr-compare {
    position: relative;
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
    user-select: none;
    cursor: col-resize;
    aspect-ratio: {{ section.settings.image_aspect }};
    background: color-mix(in srgb, var(--cvr-text) 10%, transparent);
    touch-action: pan-y;
  }

  #cvr-{{ section_id }} .cvr-compare__layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #cvr-{{ section_id }} .cvr-compare__layer img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  #cvr-{{ section_id }} .cvr-compare__placeholder {
    width: 100%; height: 100%;
  }

  #cvr-{{ section_id }} .cvr-compare__after  { z-index: 1; }
  #cvr-{{ section_id }} .cvr-compare__before { z-index: 2; clip-path: inset(0 50% 0 0); }

  #cvr-{{ section_id }} .cvr-compare__line {
    position: absolute;
    top: 0; bottom: 0; left: 50%;
    width: 2px;
    background: rgba(255,255,255,0.9);
    z-index: 3;
    transform: translateX(-50%);
    pointer-events: none;
  }

  #cvr-{{ section_id }} .cvr-compare__handle {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 44px; height: 44px;
    background: linear-gradient(122.72deg, rgba(255, 255, 255, 0.3) 1.75%, rgba(166, 165, 165, 0.3) 33.05%, rgba(255, 255, 255, 0.3) 97.16%);
    backdrop-filter: blur(20px);
    border-radius: 50%;
    z-index: 4;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 16px rgba(0,0,0,0.22);
    pointer-events: none;
  }

  #cvr-{{ section_id }} .cvr-compare__handle svg {
    width: 20px; height: 20px;
    stroke: var(--cvr-accent, #a07d57);
  }


  /* ────────────────────────────────────────
     STAT CARD
  ──────────────────────────────────────── */
  #cvr-{{ section_id }} .cvr-stat {
    margin-top: 16px;
    background: color-mix(in srgb, var(--cvr-bg, #f8f6f3) 60%, #fff);
    border-radius: {{ section.settings.image_radius }}px;
    display: flex;
    gap: 8px;
    align-items: center;
  }

  #cvr-{{ section_id }} .cvr-stat__number {
    font-size: 60px;
    font-weight: 400;
    line-height: 1;
    color: #CA003D;
    margin-bottom: 8px;
  }

  #cvr-{{ section_id }} .cvr-stat__number span {
    font-size: 26px;
  }

  #cvr-{{ section_id }} .cvr-stat__desc {
    font-size: 18px;
    font-weight: 400;
    line-height: 22px;
    color: var(--cvr-text);
    margin:0;
  }

  /* ────────────────────────────────────────
     CTA BUTTON
  ──────────────────────────────────────── */
  #cvr-{{ section_id }} .cvr-cta-wrap {
    display: flex;
      justify-content: center;
      align-items: center;
    margin-top: 32px;
  }

  /* ────────────────────────────────────────
     MOBILE LAYOUT  ≤ 768px
  ──────────────────────────────────────── */
  {% comment %} @media screen and (max-width: 768px) { {% endcomment %}
  @media screen and (max-width: 991px) {
    #cvr-{{ section_id }} {
    padding-top: 50px;
    padding-bottom: 50px;
  }
  #cvr-{{ section_id }} .main-container{
    padding-left: 15px;
    padding-right: 15px;
  }
    #cvr-{{ section_id }} .cvr-container{
    }
    #cvr-{{ section_id }} .cvr-desktop { display: none; }
    #cvr-{{ section_id }} .cvr-mobile  { display: block; }

    #cvr-{{ section_id }} .cvr-mob-header {
      margin-bottom: 28px;
    }

    #cvr-{{ section_id }} .cvr-mob-header .cvr-heading {
      font-size: 30px;
