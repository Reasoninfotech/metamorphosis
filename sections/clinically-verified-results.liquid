<script>
  (function () {
    'use strict';

    const sectionEl = document.getElementById('cvr-{{ section_id }}');
    if (!sectionEl) return;

    /* ── DESKTOP TAB SWITCH ── */
    sectionEl.querySelectorAll('.cvr-tab-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const sectionId = btn.dataset.section;
        const idx = btn.dataset.tabIndex;

        sectionEl.querySelectorAll('.cvr-tab-btn').forEach(function (b) {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        sectionEl.querySelectorAll('.cvr-panel').forEach(function (p) {
          p.classList.remove('active');
        });

        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');

        const panel = document.getElementById('cvr-panel-' + sectionId + '-' + idx);
        if (panel) panel.classList.add('active');
      });
    });

    /* ── MOBILE ACCORDION ── */
    sectionEl.querySelectorAll('[data-mob-trigger]').forEach(function (trigger) {
      trigger.addEventListener('click', function () {
        const bodyId = trigger.getAttribute('aria-controls');
        const body = document.getElementById(bodyId);
        const isOpen = trigger.classList.contains('open');

        /* close all */
        sectionEl.querySelectorAll('[data-mob-trigger]').forEach(function (t) {
          t.classList.remove('open');
          t.setAttribute('aria-expanded', 'false');
        });
        sectionEl.querySelectorAll('.cvr-mob-tab__body').forEach(function (b) {
          b.classList.remove('open');
        });

        /* open clicked (if it was closed) */
        if (!isOpen) {
          trigger.classList.add('open');
          trigger.setAttribute('aria-expanded', 'true');
          if (body) body.classList.add('open');
        }
      });
    });

    /* ── BEFORE/AFTER SLIDER ── */
    function initSlider(wrap) {
      const before = wrap.querySelector('[data-before]');
      const line = wrap.querySelector('[data-line]');
      const handle = wrap.querySelector('[data-handle]');
      if (!before) return;

      let dragging = false;

      function setPos(clientX) {
        const rect = wrap.getBoundingClientRect();
        const pct = Math.max(2, Math.min(98, ((clientX - rect.left) / rect.width) * 100));
        before.style.clipPath = 'inset(0 ' + (100 - pct) + '% 0 0)';
        if (line) line.style.left = pct + '%';
        if (handle) handle.style.left = pct + '%';
      }

      wrap.addEventListener('mousedown', function (e) {
        dragging = true;
        setPos(e.clientX);
        e.preventDefault();
      });

      wrap.addEventListener(
        'touchstart',
        function (e) {
          dragging = true;
          setPos(e.touches[0].clientX);
        },
        { passive: true }
      );

      document.addEventListener('mousemove', function (e) {
        if (dragging) setPos(e.clientX);
      });

      document.addEventListener(
        'touchmove',
        function (e) {
          if (dragging) setPos(e.touches[0].clientX);
        },
        { passive: true }
      );

      document.addEventListener('mouseup', function () {
        dragging = false;
      });
      document.addEventListener('touchend', function () {
        dragging = false;
      });
    }

    sectionEl.querySelectorAll('[data-slider]').forEach(initSlider);
  })();
</script>

