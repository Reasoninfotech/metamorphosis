    #cvr-{{ section_id }} .cvr-mob-tab__label {
      font-size: 14px;
      font-weight: 500;
      text-transform: uppercase;
      color: color-mix(in srgb, var(--cvr-text) 50%, transparent);
      transition: color 0.25s;
      font-family: var(--argentum);
      line-height: normal;
    }
     #cvr-{{ section_id }} .cvr-stat{
      margin-top: 8px;
    }

    #cvr-{{ section_id }} .cvr-mob-tab__icon {
      width: 22px; height: 22px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
