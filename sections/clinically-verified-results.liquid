{% comment %}
  Section: Clinically Verified Results
  File: sections/clinically-verified-results.liquid

  FEATURES:
  - Two tabs (configurable labels)
  - Each tab: 2 before/after image sliders side by side
  - Stat percentage + description per slider
  - CTA button per tab
  - Desktop: sticky left column + right content panels
  - Mobile: accordion-style tabs with vertical stacked sliders
  - Full schema settings for all content, colors, spacing
{% endcomment %}

{%- liquid
  assign section_id = section.id
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
  assign accent_color = section.settings.accent_color
  assign section_padding_top = section.settings.padding_top
  assign section_padding_bottom = section.settings.padding_bottom
-%}

<section
  id="cvr-{{ section_id }}"
  class="cvr-section"
  style="
    --cvr-bg:           {{ bg_color }};
    --cvr-text:         {{ text_color }};
    --cvr-accent:       {{ accent_color }};
    --cvr-pt:           {{ section_padding_top }}px;
    --cvr-pb:           {{ section_padding_bottom }}px;
  "
>
  <!--
    ════════════════════════════
         DESKTOP LAYOUT
    ════════════════════════════
  -->
  <div class="cvr-desktop">
    <div class="main-container">
      <div class="cvr-container">
        <!-- LEFT sticky column -->
        <div class="cvr-left">
          <div class="cvr-content">
            {%- if section.settings.badge != blank -%}
              <span class="cvr-badge">{{ section.settings.badge }}</span>
            {%- endif -%}

            {%- if section.settings.heading != blank -%}
              <{{ section.settings.heading_tag }} class="cvr-heading">
                {{ section.settings.heading }}
              </{{ section.settings.heading_tag }}>
            {%- endif -%}

            {%- if section.settings.description != blank -%}
              <p class="cvr-desc">{{ section.settings.description }}</p>
            {%- endif -%}
          </div>
          <div class="cvr-tab">
            <!-- Desktop Tabs -->
            <div class="cvr-tabs" role="tablist">
              {%- for block in section.blocks -%}
                {%- if block.type == 'tab' -%}
                  <button
                    class="cvr-tab-btn {% if forloop.first %}active{% endif %}"
                    role="tab"
                    aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                    aria-controls="cvr-panel-{{ section_id }}-{{ forloop.index }}"
                    data-tab-index="{{ forloop.index }}"
                    data-section="{{ section_id }}"
                    {{ block.shopify_attributes }}
                  >
                    <span class="cvr-tab-btn__text">{{ block.settings.tab_label }}</span>
                    <span class="cvr-tab-btn__arrow" aria-hidden="true">
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M9 18l6-6-6-6"/>
                      </svg>
                    </span>
                  </button>
                {%- endif -%}
              {%- endfor -%}
            </div>

            {%- if section.settings.footnote != blank -%}
              <p class="cvr-footnote">{{ section.settings.footnote }}</p>
            {%- endif -%}
          </div>
        </div>
        <!-- /cvr-left -->

        <!-- RIGHT panels -->
        <div class="cvr-panels">
          {%- for block in section.blocks -%}
            {%- if block.type == 'tab' -%}
              <div
                class="cvr-panel {% if forloop.first %}active{% endif %}"
                id="cvr-panel-{{ section_id }}-{{ forloop.index }}"
                role="tabpanel"
                {{ block.shopify_attributes }}
              >
                <div class="cvr-sliders-row">
                  <!-- Slider 1 -->
                  <div class="cvr-slider-col">
                    {% comment %}
                      {%- if section.settings.after_label != blank -%}
                        <h5 class="cvr-after-label">{{ section.settings.after_label }}</h5>
                      {%- endif -%}
                    {% endcomment %}
                    {%- if block.settings.after_label_1 != blank -%}
                      <h5 class="cvr-after-label">{{ block.settings.after_label_1 }}</h5>
                    {%- endif -%}
                    <div
                      class="cvr-compare"
                      id="slider-{{ section_id }}-{{ forloop.index }}-1"
                      data-slider
                    >
                      <div class="cvr-compare__layer cvr-compare__after">
                        {%- if block.settings.after_image_1 != blank -%}
                          <img
                            src="{{ block.settings.after_image_1 | image_url: width: 800 }}"
                            alt="{{ block.settings.after_image_1.alt | escape | default: 'After' }}"
                            width="{{ block.settings.after_image_1.width }}"
                            height="{{ block.settings.after_image_1.height }}"
                            loading="lazy"
                          >
                        {%- else -%}
                          <div
                            class="cvr-compare__placeholder"
                            style="background:linear-gradient(160deg,#f0e2d6,#d4b89a);"
                          ></div>
                        {%- endif -%}
                      </div>
                      <div class="cvr-compare__layer cvr-compare__before" data-before>
                        {%- if block.settings.before_image_1 != blank -%}
                          <img
                            src="{{ block.settings.before_image_1 | image_url: width: 800 }}"
                            alt="{{ block.settings.before_image_1.alt | escape | default: 'Before' }}"
                            width="{{ block.settings.before_image_1.width }}"
                            height="{{ block.settings.before_image_1.height }}"
                            loading="lazy"
                          >
                        {%- else -%}
                          <div
                            class="cvr-compare__placeholder"
                            style="background:linear-gradient(160deg,#c0907a,#96604a);"
                          ></div>
                        {%- endif -%}
                      </div>
                      <div class="cvr-compare__line" data-line></div>
                      <div class="cvr-compare__handle" data-handle>
                        <svg xmlns="http://www.w3.org/2000/svg" width="23" height="18" viewBox="0 0 23 18" fill="none">
                          <path d="M12.0006 0.75V17.25C12.0006 17.4489 11.9216 17.6397 11.7809 17.7803C11.6403 17.921 11.4495 18 11.2506 18C11.0517 18 10.8609 17.921 10.7203 17.7803C10.5796 17.6397 10.5006 17.4489 10.5006 17.25V0.75C10.5006 0.551088 10.5796 0.360322 10.7203 0.21967C10.8609 0.0790178 11.0517 0 11.2506 0C11.4495 0 11.6403 0.0790178 11.7809 0.21967C11.9216 0.360322 12.0006 0.551088 12.0006 0.75ZM8.25059 8.25H2.5609L4.28121 6.53062C4.42195 6.38989 4.50101 6.19902 4.50101 6C4.50101 5.80098 4.42195 5.6101 4.28121 5.46937C4.14048 5.32864 3.94961 5.24958 3.75059 5.24958C3.55157 5.24958 3.3607 5.32864 3.21996 5.46937L0.219965 8.46937C0.150233 8.53903 0.0949134 8.62175 0.0571702 8.71279C0.019427 8.80384 0 8.90144 0 9C0 9.09856 0.019427 9.19616 0.0571702 9.2872C0.0949134 9.37825 0.150233 9.46097 0.219965 9.53062L3.21996 12.5306C3.3607 12.6714 3.55157 12.7504 3.75059 12.7504C3.94961 12.7504 4.14048 12.6714 4.28121 12.5306C4.42195 12.3899 4.50101 12.199 4.50101 12C4.50101 11.801 4.42195 11.6101 4.28121 11.4694L2.5609 9.75H8.25059C8.4495 9.75 8.64027 9.67098 8.78092 9.53033C8.92157 9.38968 9.00059 9.19891 9.00059 9C9.00059 8.80109 8.92157 8.61032 8.78092 8.46967C8.64027 8.32902 8.4495 8.25 8.25059 8.25ZM22.2812 8.46937L19.2812 5.46937C19.1405 5.32864 18.9496 5.24958 18.7506 5.24958C18.5516 5.24958 18.3607 5.32864 18.22 5.46937C18.0792 5.6101 18.0002 5.80098 18.0002 6C18.0002 6.19902 18.0792 6.38989 18.22 6.53062L19.9403 8.25H14.2506C14.0517 8.25 13.8609 8.32902 13.7203 8.46967C13.5796 8.61032 13.5006 8.80109 13.5006 9C13.5006 9.19891 13.5796 9.38968 13.7203 9.53033C13.8609 9.67098 14.0517 9.75 14.2506 9.75H19.9403L18.22 11.4694C18.0792 11.6101 18.0002 11.801 18.0002 12C18.0002 12.199 18.0792 12.3899 18.22 12.5306C18.3607 12.6714 18.5516 12.7504 18.7506 12.7504C18.9496 12.7504 19.1405 12.6714 19.2812 12.5306L22.2812 9.53062C22.3509 9.46097 22.4063 9.37825 22.444 9.2872C22.4817 9.19616 22.5012 9.09856 22.5012 9C22.5012 8.90144 22.4817 8.80384 22.444 8.71279C22.4063 8.62175 22.3509 8.53903 22.2812 8.46937Z" fill="white"/>
                        </svg>
                      </div>
                    </div>

                    {%- if block.settings.stat_1 != blank or block.settings.stat_desc_1 != blank -%}
                      <div class="cvr-stat">
                        {%- if block.settings.stat_1 != blank -%}
                          <div class="cvr-stat__number">{{ block.settings.stat_1 }}%</div>
                        {%- endif -%}
                        {%- if block.settings.stat_desc_1 != blank -%}
                          <p class="cvr-stat__desc">{{ block.settings.stat_desc_1 }}</p>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  </div>
                  <!-- /slider-col 1 -->

                  <!-- Slider 2 -->
                  <div class="cvr-slider-col">
                    {%- if block.settings.after_label_2 != blank -%}
                      <h5 class="cvr-after-label">{{ block.settings.after_label_2 }}</h5>
                    {%- endif -%}
                    <div
                      class="cvr-compare"
                      id="slider-{{ section_id }}-{{ forloop.index }}-2"
                      data-slider
                    >
                      <div class="cvr-compare__layer cvr-compare__after">
                        {%- if block.settings.after_image_2 != blank -%}
                          <img
                            src="{{ block.settings.after_image_2 | image_url: width: 800 }}"
                            alt="{{ block.settings.after_image_2.alt | escape | default: 'After' }}"
                            width="{{ block.settings.after_image_2.width }}"
                            height="{{ block.settings.after_image_2.height }}"
                            loading="lazy"
                          >
                        {%- else -%}
                          <div
                            class="cvr-compare__placeholder"
                            style="background:linear-gradient(160deg,#ecddd6,#d0b09a);"
                          ></div>
                        {%- endif -%}
                      </div>
                      <div class="cvr-compare__layer cvr-compare__before" data-before>
                        {%- if block.settings.before_image_2 != blank -%}
                          <img
                            src="{{ block.settings.before_image_2 | image_url: width: 800 }}"
                            alt="{{ block.settings.before_image_2.alt | escape | default: 'Before' }}"
                            width="{{ block.settings.before_image_2.width }}"
                            height="{{ block.settings.before_image_2.height }}"
                            loading="lazy"
                          >
                        {%- else -%}
                          <div
                            class="cvr-compare__placeholder"
                            style="background:linear-gradient(160deg,#b48878,#8a5848);"
                          ></div>
                        {%- endif -%}
                      </div>
                      <div class="cvr-compare__line" data-line></div>
                      <div class="cvr-compare__handle" data-handle>
                        <svg xmlns="http://www.w3.org/2000/svg" width="23" height="18" viewBox="0 0 23 18" fill="none">
                          <path d="M12.0006 0.75V17.25C12.0006 17.4489 11.9216 17.6397 11.7809 17.7803C11.6403 17.921 11.4495 18 11.2506 18C11.0517 18 10.8609 17.921 10.7203 17.7803C10.5796 17.6397 10.5006 17.4489 10.5006 17.25V0.75C10.5006 0.551088 10.5796 0.360322 10.7203 0.21967C10.8609 0.0790178 11.0517 0 11.2506 0C11.4495 0 11.6403 0.0790178 11.7809 0.21967C11.9216 0.360322 12.0006 0.551088 12.0006 0.75ZM8.25059 8.25H2.5609L4.28121 6.53062C4.42195 6.38989 4.50101 6.19902 4.50101 6C4.50101 5.80098 4.42195 5.6101 4.28121 5.46937C4.14048 5.32864 3.94961 5.24958 3.75059 5.24958C3.55157 5.24958 3.3607 5.32864 3.21996 5.46937L0.219965 8.46937C0.150233 8.53903 0.0949134 8.62175 0.0571702 8.71279C0.019427 8.80384 0 8.90144 0 9C0 9.09856 0.019427 9.19616 0.0571702 9.2872C0.0949134 9.37825 0.150233 9.46097 0.219965 9.53062L3.21996 12.5306C3.3607 12.6714 3.55157 12.7504 3.75059 12.7504C3.94961 12.7504 4.14048 12.6714 4.28121 12.5306C4.42195 12.3899 4.50101 12.199 4.50101 12C4.50101 11.801 4.42195 11.6101 4.28121 11.4694L2.5609 9.75H8.25059C8.4495 9.75 8.64027 9.67098 8.78092 9.53033C8.92157 9.38968 9.00059 9.19891 9.00059 9C9.00059 8.80109 8.92157 8.61032 8.78092 8.46967C8.64027 8.32902 8.4495 8.25 8.25059 8.25ZM22.2812 8.46937L19.2812 5.46937C19.1405 5.32864 18.9496 5.24958 18.7506 5.24958C18.5516 5.24958 18.3607 5.32864 18.22 5.46937C18.0792 5.6101 18.0002 5.80098 18.0002 6C18.0002 6.19902 18.0792 6.38989 18.22 6.53062L19.9403 8.25H14.2506C14.0517 8.25 13.8609 8.32902 13.7203 8.46967C13.5796 8.61032 13.5006 8.80109 13.5006 9C13.5006 9.19891 13.5796 9.38968 13.7203 9.53033C13.8609 9.67098 14.0517 9.75 14.2506 9.75H19.9403L18.22 11.4694C18.0792 11.6101 18.0002 11.801 18.0002 12C18.0002 12.199 18.0792 12.3899 18.22 12.5306C18.3607 12.6714 18.5516 12.7504 18.7506 12.7504C18.9496 12.7504 19.1405 12.6714 19.2812 12.5306L22.2812 9.53062C22.3509 9.46097 22.4063 9.37825 22.444 9.2872C22.4817 9.19616 22.5012 9.09856 22.5012 9C22.5012 8.90144 22.4817 8.80384 22.444 8.71279C22.4063 8.62175 22.3509 8.53903 22.2812 8.46937Z" fill="white"/>
                        </svg>
                      </div>
                    </div>

                    {%- if block.settings.stat_2 != blank or block.settings.stat_desc_2 != blank -%}
                      <div class="cvr-stat">
                        {%- if block.settings.stat_2 != blank -%}
                          <div class="cvr-stat__number">{{ block.settings.stat_2 }}%</div>
                        {%- endif -%}
                        {%- if block.settings.stat_desc_2 != blank -%}
                          <p class="cvr-stat__desc">{{ block.settings.stat_desc_2 }}</p>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  </div>
                  <!-- /slider-col 2 -->
                </div>
                <!-- /sliders-row -->
              </div>
              <!-- /cvr-panel -->
            {%- endif -%}
          {%- endfor -%}
        </div>
        <!-- /cvr-panels -->
      </div>
      {%- if section.settings.cta_label != blank -%}
        <div class="cvr-cta-wrap">
          <a
            href="{{ section.settings.cta_url | default: '#' }}"
            class="cvr-cta-btn common_btn"
            {% if section.settings.cta_new_tab %}
              target="_blank" rel="noopener"
            {% endif %}
          >
            <span>{{ section.settings.cta_label }}</span>
          </a>
        </div>
      {%- endif -%}
    </div>
    <!-- /cvr-container -->
  </div>
  <!-- /cvr-desktop -->

  <!--
    ════════════════════════════
         MOBILE LAYOUT
    ════════════════════════════
  -->
  <div class="cvr-mobile">
    <div class="main-container">
      <div class="cvr-container">
        <!-- Shared header -->
        <div class="cvr-mob-header">
          {%- if section.settings.badge != blank -%}
            <span class="cvr-badge">{{ section.settings.badge }}</span>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <{{ section.settings.heading_tag }} class="cvr-heading">
              {{- section.settings.heading -}}
            </{{ section.settings.heading_tag }}>
          {%- endif -%}
          {%- if section.settings.description != blank -%}
            <p class="cvr-desc">{{ section.settings.description }}</p>
          {%- endif -%}
        </div>

        <!-- Accordion tabs -->
        <div class="cvr-mob-tabs">
          {%- for block in section.blocks -%}
            {%- if block.type == 'tab' -%}
              <div class="cvr-mob-tab" {{ block.shopify_attributes }}>
                <button
                  class="cvr-mob-tab__trigger {% if forloop.first %}open{% endif %}"
                  aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}"
                  aria-controls="cvr-mob-body-{{ section_id }}-{{ forloop.index }}"
                  data-mob-trigger
                >
                  <span class="cvr-mob-tab__label">{{ block.settings.tab_label }}</span>
                  <span class="cvr-mob-tab__icon" aria-hidden="true">
