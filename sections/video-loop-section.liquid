document.addEventListener("DOMContentLoaded", function () {

    /* =======================
       SWIPER INIT
    ======================= */
    var Swipes = new Swiper('.video_loop_slider', {
        loop: true,
        spaceBetween: 10,
        slidesPerView: 1,

        breakpoints: {
            992: {
                slidesPerView: 4,
                spaceBetween: 20,
            },
            575: {
                slidesPerView: 2.5,
                spaceBetween: 15,
            },
            420: {
                slidesPerView: 1,
                spaceBetween: 10,
            }
        },

        navigation: {
            nextEl: '.video_swiper_btn.swiper-button-next',
            prevEl: '.video_swiper_btn.swiper-button-prev',
        },

        pagination: {
            el: '.video_loop_swiper_dot .swiper-pagination',
            clickable: true,
        },

        on: {
            init: function () {
                handleMobileActiveVideo(this);
            },
            slideChange: function () {
                handleMobileActiveVideo(this);
            }
        }
    });

    /* =======================
       MOBILE ACTIVE SLIDE VIDEO
    ======================= */
    function handleMobileActiveVideo(swiper) {
        if (window.innerWidth <= 575) {

            document.querySelectorAll('.video_loop_col video').forEach(video => {
                video.pause();
                video.currentTime = 0;
                video.muted = true;
            });

            document.querySelectorAll('.video_loop_col .video_sound_button').forEach(btn => {
                btn.classList.remove('active');
            });

            // FIX 1: Badhaj slider videos na play btn ne "play_on" state ma rakho
            document.querySelectorAll('.video_loop_col .video_play_push_button').forEach(btn => {
                btn.classList.remove('active');
            });

            const activeSlide = swiper.slides[swiper.activeIndex];
            const activeVideo = activeSlide ? activeSlide.querySelector('video') : null;

            if (activeVideo) {
                activeVideo.muted = true;
                activeVideo.play().then(() => {
                    // FIX 1: Video play thay tyare pan play icon j dekhadvanu (autoplay = no user pause)
                    const $btn = $(activeSlide).find('.video_play_push_button');
                    $btn.removeClass('active');
                }).catch(() => {});
            }
        }
    }

    /* =======================
       UTILITY: Slider video play karo + btn state set karo
    ======================= */
    function resumeSliderVideos() {
        if (window.innerWidth <= 575) {
            handleMobileActiveVideo(Swipes);
        } else {
            document.querySelectorAll('.video_loop_col video').forEach(function (v) {
                v.muted = true;
                v.play().then(() => {
                    // FIX 1: Autoplay thay che to pause icon (active) dekhadvanu
                    const $btn = $(v).closest('.video_loop_col').find('.video_play_push_button');
                    $btn.addClass('active');
                }).catch(() => {});
            });
        }
    }

    /* =======================
       iOS INLINE VIDEO FIX
    ======================= */
    if (/iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream) {
        document.querySelectorAll('video').forEach(video => {
            video.setAttribute('playsinline', '');
        });
    }

    /* =======================
       JQUERY CONTROLS
    ======================= */
    $(document).ready(function () {

        // FIX 1: Page load thay tyare slider videos autoplay che to pause icon dekhadvanu
        document.querySelectorAll('.video_loop_col video').forEach(function (v) {
            v.addEventListener('play', function () {
                const $btn = $(v).closest('.video_loop_col').find('.video_play_push_button');
                $btn.addClass('active');
            });
            v.addEventListener('pause', function () {
                const $btn = $(v).closest('.video_loop_col').find('.video_play_push_button');
                $btn.removeClass('active');
            });
        });

        // FIX 3: Popup video autoplay che to pause icon dekhadvanu
        document.querySelectorAll('.video_loop_popup_block video').forEach(function (v) {
            v.addEventListener('play', function () {
                const $btn = $(v).closest('.popup_video_block').find('.video_play_push_button');
                $btn.addClass('active');
            });
            v.addEventListener('pause', function () {
                const $btn = $(v).closest('.popup_video_block').find('.video_play_push_button');
                $btn.removeClass('active');
            });
        });

        /* ---- SOUND TOGGLE (FIX 2) ---- */
        $('.video_loop_col .video_sound_button').on('click', function (e) {
            e.stopPropagation();

            const $btn = $(this);
            const video = $btn.closest('.video_loop_col').find('video').get(0);

            if (!video.muted) {
                // Sound on che to off karo
                video.muted = true;
                $btn.removeClass('active');
            } else {
                // Sound off che to on karo — pehla badhana mute karo
                $('.video_loop_col video').each(function () {
                    this.muted = true;
                    $(this).closest('.video_loop_col')
                           .find('.video_sound_button')
                           .removeClass('active');
                });
                video.muted = false;
                $btn.addClass('active');
            }
        });

        /* ---- PLAY / PAUSE ---- */
        $('.video_loop_col .video_play_push_button').on('click', function (e) {
            e.stopPropagation();

            const $btn = $(this);
            const video = $btn.closest('.video_loop_col').find('video').get(0);

            if (video.paused) {
                video.play();
                $btn.addClass('active');
            } else {
                video.pause();
                $btn.removeClass('active');
            }
        });

        /* ---- OPEN POPUP ---- */
        $('.video_loop_col').on('click', function (e) {
            if ($(e.target).closest('.video_sound_button, .video_play_push_button').length) return;

            const index = $(this).data('index');

            $('.video_loop_popup_block').hide();

            const $popup = $('.video_loop_popup_block[data-index="' + index + '"]');
            $popup.css({ display: 'flex', opacity: 0 }).animate({ opacity: 1 }, 200);

            // Slider videos pause karo
            $('.video_loop_col video').each(function () {
                this.muted = true;
                this.pause();
            });

            // FIX 3 + FIX 4: Popup video reset kari ne autoplay karo
            const popupVideo = $popup.find('video').get(0);
            if (popupVideo) {
                popupVideo.currentTime = 0;
                popupVideo.muted = true;
                popupVideo.play().catch(() => {});
            }
        });

        /* ---- CLOSE POPUP ---- */
        $('.video_loop_popup_block, .video_popup_close').on('click', function (e) {
            if ($(e.target).closest('.popup_video_block, .popup_product_block').length) return;

            const $popup = $(this).closest('.video_loop_popup_block');
            const popupVideo = $popup.find('video').get(0);

            // FIX 3: Popup video pause + reset karo
            if (popupVideo) {
                popupVideo.pause();
                popupVideo.currentTime = 0;
                popupVideo.muted = true;

                // Popup play btn reset karo
                $popup.find('.video_play_push_button').removeClass('active');
                $popup.find('.video_sound_button').removeClass('active');
            }

            $popup.hide();

            // Slider videos resume karo
            resumeSliderVideos();
        });

        /* ---- POPUP PLAY / PAUSE ---- */
        $('.video_loop_popup_block .video_play_push_button').on('click', function (e) {
            e.stopPropagation();

            const $btn = $(this);
            const video = $btn.closest('.popup_video_block').find('video').get(0);

            if (video.paused) {
                video.play();
                $btn.addClass('active');
            } else {
                video.pause();
                $btn.removeClass('active');
            }
        });

        /* ---- POPUP SOUND ---- */
        $('.video_loop_popup_block .video_sound_button').on('click', function (e) {
            e.stopPropagation();

            const $btn = $(this);
            const video = $btn.closest('.popup_video_block').find('video').get(0);

            if (!video.muted) {
                video.muted = true;
                $btn.removeClass('active');
            } else {
                video.muted = false;
                $btn.addClass('active');
            }
        });

    });

