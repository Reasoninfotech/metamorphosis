{% style %}

.affiliate-banner-section .affiliate-banner-wrp{position: relative;} 

.affiliate-banner-section figure img{width:100%;vertical-align: middle;}
.affiliate-banner-section .mobile-img{display:none;} 
  
.affiliate-banner-section .affiliate-banner-content{position: absolute;top: 0;left: 0;text-align: center;display: flex;align-items: center;justify-content: center;width: 100%;height: 100%;}  
.affiliate-banner-section .main_title{font-size: 75px;line-height: 75px;}
.affiliate-banner-section .main_title span{font-style: italic;}

.affiliate-banner-section .affiliate-content p{font-size: 20px;color: #000;line-height: normal;}
.affiliate-banner-section .affiliate-content p br{display:none;}

@media screen and (max-width:1439px){
  .affiliate-banner-section .main_title {font-size: 65px;line-height: 65px;}
}

@media screen and (max-width:1199px){
  .affiliate-banner-section .main_title {font-size: 55px;line-height: 55px;}
}

@media screen and (max-width:991px){
  .affiliate-banner-section .main_title {font-size: 50px;line-height: 50px;}
  .affiliate-banner-section .affiliate-content p{font-size: 18px;}
}  

@media screen and (max-width:767px){
  .affiliate-banner-section .desktop-img{display:none;}
  .affiliate-banner-section .mobile-img,
  .affiliate-banner-section .affiliate-content p br{display:block;} 
}  
  
{% endstyle %}

<div class="affiliate-banner-section">
  <div class="affiliate-banner-wrp">
  {% if section.settings.img != blank or section.settings.mobile_img != blank %}
    <figure>
      <img class="desktop-img" src="{{ section.settings.img | img_url : "master" }}" loading="lazy">
      <img class="mobile-img" src="{{ section.settings.mobile_img | img_url : "master" }}" loading="lazy">
    </figure>
    {% endif %}
    <div class="affiliate-banner-content">
      <div class="page-width">
        {% if section.settings. title != blank %}
          <h1 class="main_title">{{ section.settings.title }}</h1>
        {% endif %}
        {% if section.settings.content != blank %}
        <div class="affiliate-content">{{ section.settings.content }}</div>
        {% endif %}
      </div>  
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Affiliate Banner Section",
    "settings": [
       {
        "type": "image_picker",
        "id" : "img",
        "label": "Desktop Image"
      },
      {
        "type": "image_picker",
        "id" : "mobile_img",
        "label": "Mobile Image"
      },
      {
        "type": "html",
        "id" : "title",
        "label": "Title"
      },
      {
        "type": "html",
        "id" : "content",
        "label": "Content"
      }
    ],
    "presets": [
      {
        "name": "Affiliate Banner Section",
      }
    ]
  }
{% endschema %}