{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'newsletter-section.css' | asset_url | stylesheet_tag }}

{% style %}
  .klaviyo-form-XxPbRU .needsclick input{
    border-top: 0!important;
    border-left: 0!important;
    border-right: 0!important;
    font-family: var(--argentum)!important;
    padding-left:0!important; 
  }

  .klaviyo-form-XxPbRU .needsclick input:focus-visible{
    outline-width:unset!important;
    outline-style: unset!important;
    outline-color: unset!important;
    outline-offset: unset!important; 
    box-shadow: unset!important;
  }

  .klaviyo-form-XxPbRU .needsclick button{
    display: inline-block;
    min-width: 310px;
    text-align: center;
    font-family: var(--argentum);
    transition: .4s;
    text-decoration: none;
    cursor: pointer;
    font-weight: 300;
  }

  .klaviyo-form-XxPbRU .needsclick h1 span.ql-font-nunito-sans{
    font-family: var(--cormorant)!important;
    font-weight: 500!important;
    color: #ca003d!important;
  }

  @media screen and (max-width:575px){
      .klaviyo-form-XxPbRU .needsclick button{
            /* min-width: 280px; */
			min-width: 100%;
      }
  }
  
{% endstyle %}


<div class="newsletter {% if section.settings.border_top -%}section-border-top{%- endif -%} pt_90 pb_90" style="background:{{ section.settings.back_color }}">
	<div class="container {% if section.settings.border_top -%}section-border-top__inner{%- endif -%}">
		<div class="newsletter__item">
			<div class="newsletter__inner">
				<div class="subtitle">{{ section.settings.sub_title }}</div>
				<h2 class="main_title">{{ section.settings.heading }}</h2>
                <div class="newsletter__text rte">{{ section.settings.newsletter_text }}</div>
			</div>
			<div class="newsletter__inner">
				<div class="newsletter__form">
                  {% comment %}
                 {% form 'customer', class: 'newsletter-form' %}
						<div class="newsletter-form__inner">
							<input type="hidden" name="contact[tags]" value="newsletter">
							<div class="newsletter-form__field-wrapper">
								<div class="field">
									<input
										id="NewsletterForm--{{ section.id }}"
										type="email"
										name="contact[email]"
										class="field__input"
										value="{{ form.email }}"
										aria-required="true"
										autocorrect="off"
										autocapitalize="off"
										autocomplete="email"
										{% if form.errors %}
											autofocus
											aria-invalid="true"
											aria-describedby="Newsletter-error--{{ section.id }}"
										{% elsif form.posted_successfully? %}
											aria-describedby="Newsletter-success--{{ section.id }}"
										{% endif %}
										placeholder="{{ 'newsletter.label' | t }}"
										required
									>
									<label class="field__label" for="NewsletterForm--{{ section.id }}" type="hidden">
										{{ 'newsletter.label' | t }}
									</label>
								</div>
								{%- if form.errors -%}
									<small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">{% render 'icon-error' %}{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</small>
								{%- endif -%}
							</div>
							<button type="submit" class="common_btn" name="commit">
								<span>SIGN UP FOR MORE MAGIC</span>
							</button>
						</div>
						{%- if form.posted_successfully? -%}
							<h3 class="newsletter-form__message newsletter-form__message--success form__message" id="Newsletter-success--{{ section.id }}" tabindex="-1" autofocus>{% render 'icon-success' %}{{ 'newsletter.success' | t }}</h3>
						{%- endif -%}
					{% endform %}
                   {% endcomment %}
                  
                  <div class="klaviyo-form-XxPbRU"></div>
				</div>
			</div>
		</div>
	</div>
</div>


{% schema %}
{
	"name": "t:sections.newsletter.name",
	"tag": "section",
	"class": "spaced-section newsletter_custom",
	"enabled_on": {
    "templates": ["*"]
  },
	"settings": [
        {
          "type": "color",
          "id": "back_color",
          "label": "Background",
          "default": "#FAFAFA"
        },
		{
			"type": "richtext",
			"id": "heading",
			"default": "<p>Heading for subscribe form</p>",
			"label": "t:sections.newsletter.settings.heading.label"
		},
		{
			"type": "checkbox",
			"id": "heading_animation",
			"default": true,
			"label": "t:sections.newsletter.settings.heading_animation.label"
		},
		{
			"type": "text",
			"id": "sub_title",
			"default": "Subheading",
			"label": "t:sections.newsletter.settings.sub_title.label"
		},
		{
			"type": "html",
			"id": "newsletter_text",
			"default": "<p>Additional text for subscribe form.</p>",
			"label": "t:sections.newsletter.settings.newsletter_text.label"
		},
		{
			"type": "select",
			"id": "button_style",
			"options": [
				{
					"value": "primary",
					"label": "t:sections.newsletter.settings.button_style.options__1.label"
				},
				{
					"value": "secondary",
					"label": "t:sections.newsletter.settings.button_style.options__2.label"
				}
			],
			"default": "secondary",
			"label": "t:sections.newsletter.settings.button_style.label",
			"info": "t:sections.newsletter.settings.button_style.info"
		},
		{
			"type": "paragraph",
			"content": "t:sections.newsletter.settings.paragraph.content"
		},
		{
			"type": "checkbox",
			"id": "border_top",
			"default": false,
			"label": "t:sections.newsletter.settings.border_top.label"
		}
	],
	"presets": [
		{
			"name": "Newsletter"
		}
	]
}
{% endschema %}
