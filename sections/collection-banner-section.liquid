{{ 'collection-banner-section.css' | asset_url | stylesheet_tag }}

<div class="collection-banner-section{% if section.settings.padding_bottom == true %} pb_90{% endif %}">
  <div class="collection-banner-wrp">
    {% if section.settings.desktop_image != blank or section.settings.mobile_image != blank %}
    <figure>
      <img src="{{ section.settings.desktop_image | img_url : "master" }}" class="collection-desktop-banner" loading="lazy"> 
      <img src="{{ section.settings.mobile_image | img_url : "master" }}" class="collection-mobile-banner" loading="lazy">
    </figure>
    {% endif %}
    <div class="collection-text-block">
      <div class="page-width">
        <div  class="collection_text_block_wrp">
          {% if section.settings.star_text != blank %}
            <div class="star-rating">
              <div class="star_rating_block">
                {% for i in (1..5) %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <path d="M13.0771 15.056C13.1063 15.2047 13.0576 15.3533 12.9309 15.4425C12.814 15.5317 12.6581 15.5417 12.5314 15.4624L8 12.7366L3.47837 15.4723C3.35169 15.5516 3.19577 15.5417 3.07883 15.4525C2.96189 15.3632 2.90342 15.2146 2.93265 15.0659L4.08255 9.84239L0.126125 6.29398C0.0189316 6.19486 -0.0297929 6.03627 0.0189316 5.8975C0.0676561 5.75874 0.184595 5.64971 0.330768 5.6398L5.57352 5.1343L7.65893 0.227971C7.7174 0.089206 7.85383 0 8 0C8.14617 0 8.2826 0.089206 8.34107 0.227971L10.4265 5.14421L15.6692 5.6398C15.8154 5.64971 15.9421 5.75874 15.9811 5.8975C16.0298 6.03627 15.9811 6.19486 15.8739 6.29398L11.9272 9.83248L13.0868 15.056H13.0771Z" fill="#FFE600"/>
                    </svg>
                {% endfor %}
              </div>
              <span style="color:{{ section.settings.text_color }}">{{ section.settings.star_text }}</span>
            </div>
            {% endif %}
          {% if section.settings.sub_text != blank %}<span class="collection-subtext" style="color:{{ section.settings.text_color }}">{{ section.settings.sub_text }}</span>{% endif %}
          {{ section.settings.title }}
          {% if section.settings.content != blank %}
            <div class="collection_content" style="color:{{ section.settings.text_color }}">{{ section.settings.content }}</div>
          {% endif %}  
        </div>
    </div>
    </div>
  </div>
</div>



{% schema %}
  {
    "name": "Collection Banner Section", 
    "settings": [
       {
        "type": "checkbox",
        "id": "padding_bottom",
        "label": "Padding Bottom",
        "default": true
       },
       {
        "type": "color",
        "id": "text_color",
        "label": "Text Color",
        "default": "#000"
       },
       {
        "type": "image_picker",
        "id": "desktop_image",
        "label": "Desktop Image"
      },
       {
        "type": "image_picker",
        "id": "mobile_image",
        "label": "Mobile Image"
      },
      {
          "type": "text",
          "id": "star_text",
          "label": "Star Text"
      },
      {
        "type":"text",
        "id":"sub_text",
        "label":"Sub text"
      },
      {
        "type":"html",
        "id":"title",
        "label":"Title",
        "default": "EMBRACE RADIANT WITH LED LIGHT THERAPY"
      },
      {
        "type":"richtext",
        "id":"content",
        "label":"Content",
        "default": "<p>Our bestselling devices are on so many beauty writers' most-loved lists; simply put, they're the latest and best in beauty tech. Whether your goal is smoother, brighter skin or you...</p>"
      }
    ],
    "presets": [
      {
        "name": "Collection Banner Section",
      }
    ]
  }
{% endschema %}