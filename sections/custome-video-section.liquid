      <path d="M16 0C7.16 0 0 7.16 0 16s7.16 16 16 16 16-7.16 16-16S24.84 0 16 0zM14 22c0 1-.8 2-2 2s-2-1-2-2V10c0-1 .8-2 2-2s2 1 2 2v12zm8 0c0 1-.8 2-2 2s-2-1-2-2V10c0-1 .8-2 2-2s2 1 2 2v12z"/>
    </svg>
  `;

  if (!btn && vid) {
    vid.muted = true;
    vid.loop = true;
    vid.autoplay = true;
    vid.play().catch(() => {});
  }

  if (btn && vid) {
    btn.innerHTML = playSVG;
    btn.style.transition = "opacity 0.5s ease";

    function toggleVideo() {
      if (vid.paused) {
        vid.play();
        btn.innerHTML = pauseSVG;
        btn.style.opacity = "1";
        setTimeout(() => btn.style.opacity = "0", 1000);
      } else {
        vid.pause();
        btn.innerHTML = playSVG;
        btn.style.opacity = "1";
      }
    }

    vid.addEventListener('click', toggleVideo);

    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      toggleVideo();
    });

    vid.addEventListener('ended', function () {
      vid.pause();
      vid.currentTime = 0;
      vid.load();
      btn.innerHTML = playSVG;
      btn.style.opacity = "1";
    });
  }

  if (soundBtn && vid) {
    soundBtn.addEventListener('click', function () {
      vid.muted = !vid.muted;
      if (vid.muted) {
        soundOn.style.display = 'none';
        soundOff.style.display = 'block';
      } else {
        soundOn.style.display = 'block';
        soundOff.style.display = 'none';
      }
    });
  }

});
</script>
{% schema %}
{
  "name": "Custome video section",
  "class": "header-slider",
  "settings": [
    {
      "type": "video",
      "id": "desktop_video",
      "label": "Desktop Video"
    },
    {
      "type": "image_picker",
      "id": "desktop_poster",
      "label": "Desktop Video Poster"
    },
    {
      "type": "video",
      "id": "mob_video",
      "label": "Mobile Video"
    },
    {
      "type": "image_picker",
      "id": "mobile_poster",
      "label": "Mobile Video Poster"
    },
    {
      "type": "checkbox",
      "id": "auto_loop",
      "label": "Autoplay + Loop",
      "default": true
    },
  ],
  "presets": [
    {
      "name": "Custome video section"
    }
  ]
}
{% endschema %}
