{% style %}
#section___{{ section.id }}{background-color:{{ section.settings.background_color }};}
        
.infinate_slider{padding:22px 0; overflow: hidden;}

.infinate_slider figure{margin:0;display: flex;align-items: center;height: 100%;justify-content: center;}
.infinate_slider figure img{display:block;vertical-align:middle;max-width:100%;height:150px;width: 100%;object-fit: contain;}

.infinate_slider .swiper-wrapper{transition-timing-function: linear;}
.infinate_slider .swiper-wrapper .swiper-slide{    margin-left: 6px;}
.infinate_slider .swiper-slide{height:auto;}
.infinit_artical .infinate_title{  padding: 0; font-size:17px; line-height: 24px; text-transform: uppercase;  font-family: var(--sequel-sans);margin: 0;}
.infinit_artical{ display: flex;align-items: center; padding: 6px 0;}
.infinit_artical .svg_icon{ width: 38px; height: 38px;display: flex;justify-content: center;align-items: center; background-color: #000000;border-radius: 50%;box-shadow: 0 0 0 6px rgb(0, 67, 38, 0.3);margin: 0 20px 0 0;}

.infinate_slider_inner {position: relative;display: flex;width: 100%;animation-duration: 15s;animation-iteration-count: infinite;animation-timing-function: linear;justify-content: space-between;gap: 200px;}

.infinti_scroll {display: flex;justify-content: space-between;align-items: center;gap: 200px;}

.infinit_artical {display: flex;align-items: center;padding: 6px 0;white-space: nowrap;}

.marquee{animation-name: marquee1;}

  @keyframes marquee1 {
    0% { left: 0; } 
   100% {left: -100%;}
  }

  @media screen and (max-width:1199px){
    .infinit_artical .infinate_title {font-size: 16px;line-height: 20px;}
  }  

  @media screen and (max-width:991px){
    .infinti_scroll {gap: 100px;}
  }

  @media screen and (max-width:575px){
    .infinate_slider figure img{height:80px;}
    .infinti_scroll {gap: 50px;}
    .infinate_slider_inner {animation-duration: 7s;}
  }

{% endstyle %}

<section class="infinate_slider" id="section___{{ section.id }}">
  <div class="">
    <div class="infinate_slider_inner  marquee">
      <div class="infinti_scroll">
        {% for block in section.blocks %}
          {% if block.settings.title != blank %}
            <div class="infinit_artical">
              <div class="svg_icon">{{ block.settings.svg_icon }}</div>
              <h4 class="infinate_title">{{ block.settings.title }}</h4>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
  $(document).ready(function () {
    var elements = $('.infinti_scroll .infinit_artical').length;
    for (var i = 0; i < elements; i++) {
      $('.infinti_scroll').clone().prependTo('.infinate_slider_inner ');
    }
    var liEle = [];
    var liEle = $('.infinti_scroll .infinit_artical');
  });
</script>

{% schema %}
{
  "name": "Infinate Slider",
  "class": "spacing_bootom",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color"
    }
  ],
  "blocks": [
    {
      "type": "img-text",
      "name": "Image",
      "settings": [
        {
          "type": "html",
          "id": "svg_icon",
          "label": "Svg Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Infinate Slider"
    }
  ]
}
{% endschema %}
