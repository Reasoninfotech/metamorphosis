<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "{{ shop.name | escape }}",
  "url": "{{ shop.url }}",
  {% if settings.logo != blank %}
  "logo": "{{ settings.logo | image_url: width: 400 }}",
  {% endif %}
  {% if settings.organization_contact_email != blank %}
  "contactPoint": [{
    "@type": "ContactPoint",
    "email": "{{ settings.organization_contact_email }}",
    "contactType": "customer support"
  }],
  {% endif %}
  {% if settings.organization_social_links != blank %}
  "sameAs": [
    {% assign social_links = settings.organization_social_links | split: ',' %}
    {% for link in social_links %}
      "{{ link | strip }}"{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
  {% endif %}
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "{{ settings.organization_street | escape }}",
    "addressLocality": "{{ settings.organization_city | escape }}",
    "addressRegion": "{{ settings.organization_region | escape }}",
    "postalCode": "{{ settings.organization_postal_code | escape }}",
    "addressCountry": "{{ settings.organization_country | escape }}"
  }
}
</script>