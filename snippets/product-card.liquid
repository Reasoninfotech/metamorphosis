{% comment %}
	Renders a product card

	Accepts:
	- product_card_product: {Object} Product Liquid object (optional)
	- media_size: {String} Size of the product image card. Values are "landscape", "square" and "portrait". Default is "square" (optional)
	- media_fit: {String} Fit of the product image card. Values are "contain" and "cover". Default is "contain" (optional)
	- show_secondary_image: {Boolean} Show the secondary image on hover. Default: false (optional)
	- show_vendor: {Boolean} Show the product vendor. Default: false,
	- show_desc: {Boolean} Show the product description. 120 characters max. Default: false,
	- show_sku: {Boolean} Show sku. Default: false


	Usage:
{% render 'product-card', show_vendor: section.settings.show_vendor %}
{% endcomment %}

<a href="{{ product_card_product.url | default: '#' }}" class="link bottom_link_product link--overlay card-wrapper__link--overlay js-color-swatches-link"></a>
<div class="card-wrapper color-background-2 js-color-swatches-wrapper
	{% if show_secondary_image -%} card-wrapper_secondary-image {%- endif -%}"
	data-product = "{{ product_card_product.handle }}"
>
	{%- liquid
		assign featured_media_aspect_ratio = product_card_product.featured_media.aspect_ratio

		if product_card_product.featured_media.aspect_ratio == nil
		assign featured_media_aspect_ratio = 1
		endif -%}

	 {% if settings.show_dicount_badge == true %}
	  {% if settings.discount_badge_img != blank or product_card_product.metafields.custom.dicoount_badge != blank %}	
		<div class="dicoount_badge">
			<img src="{% if settings.discount_badge_img != blank %}{{ settings.discount_badge_img | image_url: width: 200 }}{% else %}{{ product_card_product.metafields.custom.dicoount_badge | image_url: width: 200 }}{% endif %}" alt="{{ product_card_product.metafields.custom.dicoount_badge.value | default: 'Discount badge' }}" loading="lazy" width="200" height="200">
		</div> 
	  {% endif %} 	
	{% endif %}	

	<div class="card__badge" style="display: none;">
		{%- if product_card_product.available == false -%}
			<span class="badge badge--bottom-left badge--soldout" aria-hidden="true">{{ 'products.product.sold_out' | t }}</span>
			{%- elsif product_card_product.compare_at_price > product_card_product.price and product_card_product.available -%}
			<span class="badge badge--bottom-left" aria-hidden="true">{{ 'products.product.on_sale' | t }} {% render 'icon-star' %}</span>
		{%- endif -%}
	</div>
  
	<span class="visually-hidden">{{ product_card_product.title | escape }}</span>
	<div class="card card--product" tabindex="-1">
		<div class="card__inner full-unstyled-link">

			<div>
                <div class="product_hover_img">
                  {% if product_card_product.metafields.custom.collection_hover_image != blank %}
                     <img
                       class="card-wrapper__image motion-reduce media--second"
                       src="{{ product_card_product.metafields.custom.collection_hover_image | image_url: width: 600 }}"
                       alt="{{ product_card_product.metafields.custom.collection_hover_image.alt | escape }}"
                       loading="lazy"
                       width="600"
                       height="600"
                     >
                  {% else %}
            		{%- if product_card_product.media[2] != nil and show_secondary_image -%}
            			<img srcset="{%- if product_card_product.media[2].width >= 165 -%}{{ product_card_product.media[2] | img_url: '165x' }} 165w,{%- endif -%}
            					{%- if product_card_product.media[2].width >= 360 -%}{{ product_card_product.media[2] | img_url: '360x' }} 360w,{%- endif -%}
            					{%- if product_card_product.media[2].width >= 533 -%}{{ product_card_product.media[2] | img_url: '533x' }} 533w,{%- endif -%}
            					{%- if product_card_product.media[2].width >= 720 -%}{{ product_card_product.media[2] | img_url: '720x' }} 720w,{%- endif -%}
            					{%- if product_card_product.media[2].width >= 940 -%}{{ product_card_product.media[2] | img_url: '940x' }} 940w,{%- endif -%}
            					{%- if product_card_product.media[2].width >= 1066 -%}{{ product_card_product.media[2] | img_url: '1066x' }} 1066w{%- endif -%}"
            						src="{{ product_card_product.media[2] | img_url: '533x' }}"
            						sizes="(min-width: 1100px) 535px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)"
            						alt="{{ product_card_product.media[2].alt | escape }}"
            						loading="lazy"
            						class="card-wrapper__image motion-reduce media--second ddd"
            						width="{{ product_card_product.media[2].width }}"
            						height="{{ product_card_product.media[2].height }}"
            			>
            		{%- endif -%}
                  {% endif %}
                  </div>
				<div class="media media--{{ media_size }} media--hover-effect"
					{%- if media_size == 'landscape' -%} style="padding-bottom: 0;"{%- endif -%}
					{%- if media_size == 'portrait' -%} style="padding-bottom: 130%;"{%- endif -%}
					{%- if media_size == 'square' -%} style="padding-bottom: 100%;"{%- endif -%}
				>
					{%- if product_card_product.media[1] -%}
						{%- liquid
							assign card_image_style = ''
							if media_fit == 'contain'
								assign card_image_style = 'object-fit: contain;'
							elsif media_fit == 'cover'
								assign card_image_style = 'object-fit: cover;'
							endif
						-%}
						{{ product_card_product.media[1] | image_url: width: 1066 | image_tag:
							loading: 'lazy',
							widths: '165, 360, 533, 720, 940, 1066',
							sizes: '(min-width: 1100px) 535px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)',
							class: 'motion-reduce media--first',
							alt: product_card_product.media[1].alt,
							style: card_image_style
						}}
					{%- elsif product_card_product.media[1] == blank -%}
						{{ 'product-3' | placeholder_svg_tag: 'placeholder-svg' }}
					{%- endif -%}

				</div>
			</div>

			<div class="card__badge" style="display: none;">
				{%- if product_card_product.available == false -%}
					<span class="badge badge--bottom-left badge--soldout" aria-hidden="true">{{ 'products.product.sold_out' | t }}</span>
					{%- elsif product_card_product.compare_at_price > product_card_product.price and product_card_product.available -%}
					<span class="badge badge--bottom-left" aria-hidden="true">{{ 'products.product.on_sale' | t }} {% render 'icon-star' %}</span>
				{%- endif -%}
			</div>
		</div>
	</div>

	<div class="card-information">
		<div class="card-information__wrapper">
			{%- if show_sku and product_card_product.selected_or_first_available_variant.sku.size > 0 -%}
				<p
					class="card__sku no-js-hidden"
					id="Sku-{{ section.id }}"
					role="status"
					{{ block.shopify_attributes }}
				>
					<span class="visually-hidden">{{ 'products.product.sku' | t }}:</span> {{- product_card_product.selected_or_first_available_variant.sku -}}
				</p>
			{%- endif -%}

			{%- if show_vendor and product_card_product.vendor != blank -%}
				<span class="visually-hidden">{{ 'accessibility.vendor' | t }}</span>
				<div class="сard__vendor">
					{% if settings.enable_vendor_link %}
						{{ product_card_product.vendor | link_to_vendor: class: "focus-inset" }}
					{% else %}
						{{ product_card_product.vendor }}
					{% endif %}
				</div>
			{%- endif -%}


			  {% if settings.black_friday_special == true %}

                {% if settings.black_friday_special_text != blank or product_card_product.metafields.custom.christmas_text != blank %}
			    <div class="bf_black_bar">
                  {% if settings.Image_black_friday != blank %} 
				      <img src="{{ settings.Image_black_friday | image_url: width: 200 }}" loading="lazy" alt="" width="200" height="200">
				  {% else %}
					{% if product_card_product.metafields.custom.christmas_text != blank %}
					  <img src="https://cdn.shopify.com/s/files/1/0693/9849/5445/files/giftbox_2.png?v=1764911691" alt="Metamorphosis Gift Box" loading="lazy" width="300" height="300"> 
				    {% endif %}	
				  {% endif %} 
				  {% if settings.black_friday_special_text != blank or product_card_product.metafields.custom.christmas_text != blank %}
				  <div class="bf_text_block">{% if settings.black_friday_special_text != blank %}{{ settings.black_friday_special_text }}{% else %}{{ product_card_product.metafields.custom.christmas_text }} {% endif %} </div>
				 {% endif %} 
			   </div>
			   {% endif %}

			  {% endif %}


           
			<div class="сard__vendor ddd">{{ product_card_product.metafields.custom.product_sub_text | metafield_text }}</div>


            
			
          
			<h3 class="card__title h4">
				{% if product_card_product.metafields.custom.custom_product_title != blank %}
                  {{ product_card_product.metafields.custom.custom_product_title | metafield_text }}
                {% else %}
                  {{ product_card_product.title | escape }}
                {% endif %} 
			</h3>
			
			{%- if product_card_product.metafields.custom.grid_description != blank -%}
				<div class="card__description caption-with-letter-spacing">
                  {{ product_card_product.metafields.custom.grid_description | metafield_text }}
				</div>
			{%- endif -%}
			
			{%- unless product_card_product.has_only_default_variant -%}
				{%- for option in product_card_product.options_with_values -%}
					{% liquid
						assign color_trigger = settings.trigger_swatch | handle | strip
						assign name_option = option.name | handle | strip
					%}

					{% if settings.type_color_swatch == 'custom' and color_trigger == name_option %}
						<fieldset class="product-form__wrapper js-color-swatches">
							<div class="product-form__controls-group">
								{% render 'product-variant-options', product: product_card_product, option: option, no_form_id: true %}
							</div>
						</fieldset>
					{% endif %}
				{%- endfor -%}
			{% endunless %}

			<div class="card-information__bottom">
				{% render 'price', product: product_card_product, price_class: '' %}
                {% render 'okendo-reviews-product-rating-summary', product: product_card_product %}
                {% comment %} 
				{%- if settings.quickview_show -%}
					<a class="card__link button button--simple quick-view" href="#" data-handle="{{ product_card_product.handle }}">
						<span>
							{{- 'general.card.quick__view' | t -}}
							{% render 'icon-button-arrow' %}
						</span>
					</a>
				{%- endif -%}
               {% endcomment %} 
			</div>
                          
		</div>
	</div>
        <div class="add_cart_hover">
             {%- liquid
                assign gift_card_recipient_feature_active = false
                if block.settings.show_gift_card_recipient and product_card_product.gift_card?
                  assign gift_card_recipient_feature_active = true
                endif

                assign show_dynamic_checkout = false
                if block.settings.show_dynamic_checkout and gift_card_recipient_feature_active == false
                  assign show_dynamic_checkout = true
                endif
              -%}

              <product-form class="product-form" data-hide-errors="{{ gift_card_recipient_feature_active }}">
                <div class="product-form__error-message-wrapper" role="alert" hidden>
                  <svg
                    aria-hidden="true"
                    focusable="false"
                    role="presentation"
                    class="icon icon-error"
                    viewBox="0 0 13 13"
                  >
                    <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
                    <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
                    <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
                    <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
                  </svg>
                  <span class="product-form__error-message"></span>
                </div>
                {%- assign product_form_id = 'product-form-' | append: section.id -%}      
                {%- form 'product',
                  product_card_product,
                  id: product_form_id,
                  class: 'form',
                  novalidate: 'novalidate',
                  data-type: 'add-to-cart-form'
                -%}
                  <input type="hidden" name="id" value="{{ product_card_product.selected_or_first_available_variant.id }}" disabled>

                  {%- if gift_card_recipient_feature_active -%}
                    {%- render 'gift-card-recipient-form', product: product_card_product, form: form, section: section -%}
                  {%- endif -%}

                  <div class="product-form__buttons" style="margin:0;">
                    {%- if show_dynamic_checkout -%}
                      {{ form | payment_button }}
                    {%- endif -%}
                    <button id="ProductSubmitButton-{{ section.id }}" type="submit" name="add" class="product-form__submit common_btn product-section__button"                          
                        {% if block.settings.show_dynamic_checkout and product_card_product.selling_plan_groups == empty %}button--secondary{% else %}button--primary{% endif %}
                      
                      {% if product_card_product.selected_or_first_available_variant.available == false %}
                        disabled
                      {% endif %}
                    >
                      {%- if product_card_product.selected_or_first_available_variant.available -%}
                        {{ 'products.product.add_to_cart' | t }}
                      {%- else -%}
                        {{ 'products.product.sold_out' | t }}
                      {%- endif -%}
                    </button>
                  </div>
                {%- endform -%}
              </product-form>

				<div class="technical-button_wrp">
				  {% comment %} <button class="common_btn" title="Buy" data-id="{{ product_card_product.selected_or_first_available_variant.id }}" >BUY NOW</button> {% endcomment %}
					{% comment %} my code {% endcomment %}
				  <a href=""data_url="https://metamorphosisredlighttherapy.com/cart/{{ product_card_product.selected_or_first_available_variant.id }}:" {% if product_card_product.selected_or_first_available_variant.available == false %}disabled{% endif %}  class=" buy-it-now common_btn" data-cart="{{ product_card_product.selected_or_first_available_variant.id }}" {% if product_card_product.selected_or_first_available_variant.available == false %} disabled {% endif %}>
                                          BUY IT NOW
                                           {%- render 'icon-button-arrow' -%}
                                        </a>
				
									</div>

        </div>
</div>
